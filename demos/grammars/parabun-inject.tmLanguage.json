{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Parabun Keyword Injection",
  "scopeName": "inject.parabun-keywords",
  "injectionSelector": "L:source.pts -string -comment, L:source.ptsx -string -comment, L:source.pjs -string -comment, L:source.pjsx -string -comment, L:source.pui source.ts -string -comment, L:source.pui source.js -string -comment",
  "patterns": [
    {
      "comment": "async { \u2026 } \u2014 Para async block expression (async immediately before a brace)",
      "match": "\\b(async)\\b(?=\\s*\\{)",
      "captures": {
        "1": {
          "name": "storage.modifier.async"
        }
      }
    },
    {
      "comment": "fun NAME(...) \u2014 shorthand alias for function declarations / expressions",
      "match": "\\b(fun)\\b(?=\\s*[a-zA-Z_$*(<])",
      "captures": {
        "1": {
          "name": "storage.type.function.parabun"
        }
      }
    },
    {
      "comment": "export pure async fun/function declaration",
      "match": "\\b(export)\\s+(pure)\\s+(async)\\s+(fun(?:ction)?)\\b",
      "captures": {
        "1": {
          "name": "keyword.control.export"
        },
        "2": {
          "name": "keyword.other.pure.parabun"
        },
        "3": {
          "name": "storage.modifier.async"
        },
        "4": {
          "name": "storage.type.function.parabun"
        }
      }
    },
    {
      "comment": "export pure fun/function declaration",
      "match": "\\b(export)\\s+(pure)\\s+(fun(?:ction)?)\\b",
      "captures": {
        "1": {
          "name": "keyword.control.export"
        },
        "2": {
          "name": "keyword.other.pure.parabun"
        },
        "3": {
          "name": "storage.type.function.parabun"
        }
      }
    },
    {
      "comment": "pure async fun/function declaration or expression",
      "match": "\\b(pure)\\s+(async)\\s+(fun(?:ction)?)\\b",
      "captures": {
        "1": {
          "name": "keyword.other.pure.parabun"
        },
        "2": {
          "name": "storage.modifier.async"
        },
        "3": {
          "name": "storage.type.function.parabun"
        }
      }
    },
    {
      "comment": "pure fun/function declaration or expression",
      "match": "\\b(pure)\\s+(fun(?:ction)?)\\b",
      "captures": {
        "1": {
          "name": "keyword.other.pure.parabun"
        },
        "2": {
          "name": "storage.type.function.parabun"
        }
      }
    },
    {
      "comment": "pure async arrow \u2014 pure async (x) => ... / pure async x => ...",
      "match": "\\b(pure)\\s+(async)\\b(?=\\s*(?:\\(|\\w+\\s*=>))",
      "captures": {
        "1": {
          "name": "keyword.other.pure.parabun"
        },
        "2": {
          "name": "storage.modifier.async"
        }
      }
    },
    {
      "comment": "pure arrow \u2014 pure (x) => ... / pure x => ...",
      "match": "\\b(pure)\\b(?=\\s*(?:\\(|\\w+\\s*=>))",
      "captures": {
        "1": {
          "name": "keyword.other.pure.parabun"
        }
      }
    },
    {
      "comment": "signal NAME = ... \u2014 reactive cell declaration",
      "match": "\\b(signal)\\b(?=\\s+[A-Za-z_$][\\w$]*\\s*[=,;:!])",
      "captures": {
        "1": {
          "name": "storage.type.signal.parabun"
        }
      }
    },
    {
      "comment": "source NAME = ... \u2014 native-handle reactive view, auto-disposed on unmount (.pui)",
      "match": "\\b(source)\\b(?=\\s+[A-Za-z_$][\\w$]*\\s*[=:])",
      "captures": {
        "1": {
          "name": "storage.type.source.parabun"
        }
      }
    },
    {
      "comment": "`every MS_EXPR` postfix on a signal declaration \u2014 drives the cell from an interval",
      "match": "(?<=[\\)\\d\\w$])\\s+(every)\\s+(?=\\d|[A-Za-z_$\\(])",
      "captures": {
        "1": {
          "name": "keyword.control.every.parabun"
        }
      }
    },
    {
      "comment": "derived NAME = EXPR or derived NAME { \u2026 } \u2014 read-only computed cell ($derived / $derived.by)",
      "match": "\\b(derived)\\b(?=\\s+[A-Za-z_$][\\w$]*\\s*[=,;:!{])",
      "captures": {
        "1": {
          "name": "storage.type.derived.parabun"
        }
      }
    },
    {
      "comment": "effect { ... } \u2014 block sugar for signals.effect()",
      "match": "\\b(effect)\\b(?=\\s*\\{)",
      "captures": {
        "1": {
          "name": "keyword.control.effect.parabun"
        }
      }
    },
    {
      "comment": "mount { ... } \u2014 once-after-mount lifecycle block (lowers to onMount())",
      "match": "\\b(mount)\\b(?=\\s*\\{)",
      "captures": {
        "1": {
          "name": "keyword.control.mount.parabun"
        }
      }
    },
    {
      "comment": "when not EXPR { ... } \u2014 fires on the negated edge",
      "match": "\\b(when)\\s+(not)\\b",
      "captures": {
        "1": {
          "name": "keyword.control.when.parabun"
        },
        "2": {
          "name": "keyword.control.when.not.parabun"
        }
      }
    },
    {
      "comment": "when EXPR { ... } \u2014 fires on the rising edge",
      "match": "\\b(when)\\b(?=\\s+[!A-Za-z_$])",
      "captures": {
        "1": {
          "name": "keyword.control.when.parabun"
        }
      }
    },
    {
      "comment": "trailing `start` modifier \u2014 initial-truthy + edge",
      "match": "\\b(start)\\b(?=\\s*\\{)",
      "captures": {
        "1": {
          "name": "keyword.control.when.start.parabun"
        }
      }
    },
    {
      "comment": "paired `when stop { }` arm \u2014 fires on falling edge of preceding when",
      "match": "\\b(when)\\s+(stop)\\b(?=\\s*\\{)",
      "captures": {
        "1": {
          "name": "keyword.control.when.parabun"
        },
        "2": {
          "name": "keyword.control.when.stop.parabun"
        }
      }
    },
    {
      "comment": "arena { ... } \u2014 DeferGC scope",
      "match": "\\b(arena)\\b(?=\\s*\\{)",
      "captures": {
        "1": {
          "name": "keyword.control.arena.parabun"
        }
      }
    },
    {
      "comment": "memo async NAME( \u2014 statement-form async memoized fn",
      "match": "\\b(memo)\\s+(async)\\s+(?=[A-Za-z_$][\\w$]*\\s*(?:<|\\())",
      "captures": {
        "1": {
          "name": "keyword.other.memo.parabun"
        },
        "2": {
          "name": "storage.modifier.async"
        }
      }
    },
    {
      "comment": "memo NAME( \u2014 statement-form memoized fn (sync)",
      "match": "\\b(memo)\\s+(?!async\\b)(?=[A-Za-z_$][\\w$]*\\s*(?:<|\\())",
      "captures": {
        "1": {
          "name": "keyword.other.memo.parabun"
        }
      }
    },
    {
      "comment": "memo async (...) / memo async NAME => \u2014 async arrow form",
      "match": "\\b(memo)\\s+(async)\\s+(?=\\(|[A-Za-z_$][\\w$]*\\s*=>)",
      "captures": {
        "1": {
          "name": "keyword.other.memo.parabun"
        },
        "2": {
          "name": "storage.modifier.async"
        }
      }
    },
    {
      "comment": "memo (...) / memo <T>(...) / memo NAME => \u2014 sync arrow form",
      "match": "\\b(memo)\\s+(?=\\(|<[\\w\\s,=]+>\\s*\\(|[A-Za-z_$][\\w$]*\\s*=>)",
      "captures": {
        "1": {
          "name": "keyword.other.memo.parabun"
        }
      }
    },
    {
      "comment": "defer EXPR / defer await EXPR \u2014 block-exit hook (LIFO)",
      "match": "\\b(defer)\\b(?=\\s+[A-Za-z_$])",
      "captures": {
        "1": {
          "name": "keyword.control.defer.parabun"
        }
      }
    },
    {
      "comment": "~> reactive-binding operator \u2014 `src ~> dst` wraps in signals.effect(() => { dst = src })",
      "match": "~>",
      "name": "keyword.operator.rbind.parabun"
    },
    {
      "comment": "-> reactive call-binding operator (negative lookbehind guards against `-->` / `=>` / `<-`)",
      "match": "(?<![\\-=<])->",
      "name": "keyword.operator.callbind.parabun"
    },
    {
      "comment": "export schema NAME from <expr> \u2014 exported JSON Schema ingestion",
      "match": "\\b(export)\\s+(schema)\\s+([A-Za-z_$][\\w$]*)\\s+(from)\\b",
      "captures": {
        "1": {
          "name": "keyword.control.export.ts"
        },
        "2": {
          "name": "storage.type.schema.parabun"
        },
        "3": {
          "name": "entity.name.type.schema.parabun"
        },
        "4": {
          "name": "keyword.control.from.parabun"
        }
      }
    },
    {
      "comment": "schema NAME from <expr> \u2014 ingest existing JSON Schema (file / fetch / inline literal)",
      "match": "\\b(schema)\\s+([A-Za-z_$][\\w$]*)\\s+(from)\\b",
      "captures": {
        "1": {
          "name": "storage.type.schema.parabun"
        },
        "2": {
          "name": "entity.name.type.schema.parabun"
        },
        "3": {
          "name": "keyword.control.from.parabun"
        }
      }
    },
    {
      "comment": "export schema NAME { ... } / NAME = ... \u2014 exported declaration",
      "match": "\\b(export)\\s+(schema)\\s+([A-Za-z_$][\\w$]*)\\b",
      "captures": {
        "1": {
          "name": "keyword.control.export.ts"
        },
        "2": {
          "name": "storage.type.schema.parabun"
        },
        "3": {
          "name": "entity.name.type.schema.parabun"
        }
      }
    },
    {
      "comment": "schema NAME { ... } / NAME = ... / NAME from ... \u2014 declaration",
      "match": "\\b(schema)\\s+([A-Za-z_$][\\w$]*)\\b",
      "captures": {
        "1": {
          "name": "storage.type.schema.parabun"
        },
        "2": {
          "name": "entity.name.type.schema.parabun"
        }
      }
    },
    {
      "comment": "schema { ... } \u2014 inline expression literal (no name binding)",
      "match": "\\b(schema)\\b(?=\\s*\\{)",
      "captures": {
        "1": {
          "name": "storage.type.schema.parabun"
        }
      }
    },
    {
      "comment": "Bare `schema` keyword fallback \u2014 highlights as soon as typed; skipped when followed by =/(/. (used as identifier)",
      "match": "\\b(schema)\\b(?![\\s]*[=.(])",
      "captures": {
        "1": {
          "name": "storage.type.schema.parabun"
        }
      }
    },
    {
      "comment": "match EXPR { arm, arm, \u2026 } \u2014 Para pattern matching expression",
      "begin": "\\b(match)\\b(?=\\s+[A-Za-z_$(])",
      "end": "(?<=\\})",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.match.parabun"
        }
      },
      "patterns": [
        {
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.match.begin.parabun"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.section.match.end.parabun"
            }
          },
          "patterns": [
            {
              "comment": "wildcard arm `_ => \u2026`",
              "match": "(^|,)\\s*(_)\\s*(?==>)",
              "captures": {
                "2": {
                  "name": "constant.language.wildcard.parabun"
                }
              }
            },
            {
              "comment": "match-arm fat arrow",
              "match": "=>",
              "name": "keyword.operator.arrow.match.parabun"
            },
            {
              "include": "source.ts"
            }
          ]
        },
        {
          "include": "source.ts"
        }
      ]
    },
    {
      "comment": ":: per-arg runtime validation marker \u2014 `fn(req:: User) {...}` injects User.parse(req) at entry",
      "match": "::",
      "name": "keyword.operator.validate.parabun"
    },
    {
      "comment": "Ok / Err / Some \u2014 Result/Option tagged-union constructors (in call position)",
      "match": "\\b(Ok|Err|Some)\\b(?=\\s*\\()",
      "captures": {
        "1": {
          "name": "support.function.constructor.result.parabun"
        }
      }
    },
    {
      "comment": "None \u2014 bare Option constant",
      "match": "\\b(None)\\b(?!\\s*[\\.\\[\\(])",
      "captures": {
        "1": {
          "name": "constant.language.option.none.parabun"
        }
      }
    },
    {
      "comment": "Capitalized refinement / format types \u2014 Email / UUID / Url / Date / DateTime / IpV4 / IpV6 / Slug",
      "match": "(:|::)(\\s+)(Email|UUID|Url|Date|DateTime|IpV4|IpV6|Slug)\\b",
      "captures": {
        "1": {
          "name": "punctuation.separator.key-value.ts"
        },
        "3": {
          "name": "support.type.ts"
        }
      }
    },
    {
      "comment": "Lowercase primitive types \u2014 int / str / string / bool / boolean / float / num / number (in `: Type` position)",
      "match": "(:)(\\s+)(int|str|string|bool|boolean|float|num|number)\\b",
      "captures": {
        "1": {
          "name": "punctuation.separator.key-value.ts"
        },
        "3": {
          "name": "support.type.primitive.ts"
        }
      }
    },
    {
      "comment": "`expr is not Type` \u2014 runtime negated type-guard, lowers to Type.parse(expr).tag !== \"Ok\"",
      "match": "\\b(is)\\s+(not)\\b(?=\\s+[A-Z])",
      "captures": {
        "1": {
          "name": "keyword.operator.is.parabun"
        },
        "2": {
          "name": "keyword.operator.is.parabun"
        }
      }
    },
    {
      "comment": "`expr is Type` \u2014 runtime type-guard, lowers to Type.parse(expr).tag === \"Ok\"",
      "match": "\\b(is)\\b(?=\\s+[A-Z])",
      "captures": {
        "1": {
          "name": "keyword.operator.is.parabun"
        }
      }
    },
    {
      "comment": "parallel/para let|const NAME = ..., ... \u2014 fan-out promise composition (statement form)",
      "match": "\\b(parallel|para)\\s+(let|const)\\b",
      "captures": {
        "1": {
          "name": "storage.modifier.parallel.parabun"
        },
        "2": {
          "name": "storage.type.ts"
        }
      }
    },
    {
      "comment": "parallel/para { ... } \u2014 fan-out promise composition (expression form)",
      "match": "\\b(parallel|para)\\b(?=\\s*\\{)",
      "captures": {
        "1": {
          "name": "storage.modifier.parallel.parabun"
        }
      }
    },
    {
      "comment": "..= inclusive range \u2014 `a..=b` lowers to iterator over [a, b]",
      "match": "\\.\\.=",
      "name": "keyword.operator.range-inclusive.parabun"
    },
    {
      "comment": "..! error-chain operator \u2014 `p ..! handler` lowers to `p.catch(handler)`",
      "match": "\\.\\.!",
      "name": "keyword.operator.catch.parabun"
    },
    {
      "comment": "..& finally operator \u2014 `p ..& cleanup` lowers to `p.finally(cleanup)`",
      "match": "\\.\\.&",
      "name": "keyword.operator.finally.parabun"
    },
    {
      "comment": "..> then operator \u2014 `p ..> next` lowers to `p.then(next)`",
      "match": "\\.\\.>",
      "name": "keyword.operator.then.parabun"
    },
    {
      "comment": ".. exclusive range \u2014 `a..b` lowers to iterator over [a, b)",
      "match": "\\.\\.(?!\\.)",
      "name": "keyword.operator.range.parabun"
    },
    {
      "comment": "|> pipeline operator \u2014 threads LHS as first arg of RHS call",
      "match": "\\|>",
      "name": "keyword.operator.pipeline.parabun"
    },
    {
      "comment": "Nd decimal literal \u2014 `0.0825d` / `42d` route arithmetic through .add / .mul methods (exact, no FP drift)",
      "match": "(?<![\\w$.])((?:\\.\\d+|\\d+(?:\\.\\d*)?)(?:[eE][+-]?\\d+)?)(d)(?![\\w$])",
      "captures": {
        "1": {
          "name": "constant.numeric.decimal.parabun"
        },
        "2": {
          "name": "keyword.other.decimal-suffix.parabun"
        }
      }
    }
  ],
  "injectTo": [
    "source.ts",
    "source.tsx",
    "source.js",
    "source.jsx",
    "source.pts",
    "source.ptsx",
    "source.pjs",
    "source.pjsx",
    "source.pui"
  ]
}
