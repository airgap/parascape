<!--
  Parascape site Designer — a Wix/Squarespace-style page builder. You stack
  content sections (hero, text, feature columns, stats, CTA, footer); each
  section's content is a real Parascape component composition, compiled live
  via the demos' live-compiler. Per-section style (background, padding,
  alignment, content width, light/dark) is plain CSS owned here; dark sections
  render their Parascape content in awsui-dark-mode so the text stays legible.
  Reorder / duplicate / delete sections, preview at desktop/tablet/mobile
  widths, autosave to localStorage, and export the whole page to .pui.
-->
<script lang="pts">
	import { untrack } from 'svelte';
	import axe from 'axe-core';
	import * as account from '../src/lib/account';
	import type { Account, AssetMeta } from '../src/lib/account';
	import { createCollab } from '../src/lib/collab';
	import type { Presence } from '../src/lib/collab';
	import { stableStringify } from '../src/lib/collab-doc';
	import SiteNav from '../src/lib/SiteNav.pui';
	import { compileParascape, mountSvelte } from '../demos/live-compile';
	import { highlight, highlightSync, ready as shikiReady } from '../demos/pui-shiki';
	import { SECTIONS, SECTION_BY_ID, sectionSource, markupOf, importLine, esc } from './sections';
	import type { SectionStyle } from './sections';
	import { COLOR_TOKENS, RADIUS_TOKENS, SHADOW_TOKENS, SPACE_SCALE } from './theme-tokens';
	import { TEMPLATES } from './templates';
	import type { Template } from './templates';
	import {
		allComponents,
		displayName,
		takesContent,
		editableProps,
		isUnion,
		unionOptions,
		seed,
		componentOpen,
		identOf,
	} from './component-meta';

	// A node is either a preset section (type ∈ section ids, content in `values`),
	// a raw Parascape component (type === 'component', with comp/props/content),
	// or an instance of a user-defined named component (type === 'instance',
	// `ref` = the NamedComponent id; it renders that component's `def`). Container
	// components (takesContent) can hold child component nodes, so the page is a
	// tree, not a flat list — `sections` is the top-level (the stack).
	type Section = {
		key: number;
		type: string;
		values: Record<string, string>;
		style: SectionStyle;
		comp?: string;
		props?: Record<string, string | number | boolean>;
		content?: string;
		bind?: string; // LYK-945: data path bound to this node's content (e.g. "hero.title")
		propBind?: Record<string, string>; // LYK-945: prop name → data path
		source?: string; // LYK-945: for a `repeat` node — the data-array path to loop
		children?: Section[];
		ref?: string;
		// freeform placement (LYK-936): a child of a `free` section is absolutely
		// positioned by x/y (+ optional w/h).
		x?: number;
		y?: number;
		w?: number;
		h?: number;
		// per-node style overrides (LYK-933): CSS prop → value, applied to the
		// node's wrapper in preview + export (e.g. padding, color, border).
		css?: Record<string, string>;
		// responsive overrides (LYK-932): partial css applied at ≤768px (tablet)
		// and ≤480px (mobile), cascading over `css`. Exported as media queries.
		cssMd?: Record<string, string>;
		cssSm?: Record<string, string>;
	};
	const isComp = (s: Section) => s.type === 'component';
	const isContainer = (s: Section) => isComp(s) && takesContent(s.comp!);
	const isInstance = (s: Section) => s.type === 'instance';
	// A "free canvas" section: its direct children are placed freely (absolute),
	// the Builder's freeform mode folded into the Designer (LYK-936).
	const isFree = (s: Section) => s.type === 'free';
	// A "repeat" section (LYK-945): renders its children template once per item of
	// a data-array (`source`); export emits `{#each data.<source> as item}…`.
	const isRepeat = (s: Section) => s.type === 'repeat';

	// --- tree helpers (operate on the nested node tree by key) ---
	function findNode(list: Section[], key: number): Section | null {
		for (const n of list) {
			if (n.key === key) return n;
			if (n.children) {
				const c = findNode(n.children, key);
				if (c) return c;
			}
		}
		return null;
	}
	function mapTree(list: Section[], key: number, fn: (n: Section) => Section): Section[] {
		return list.map((n) => {
			if (n.key === key) return fn(n);
			if (n.children) return { ...n, children: mapTree(n.children, key, fn) };
			return n;
		});
	}
	function removeTree(list: Section[], key: number): Section[] {
		return list
			.filter((n) => n.key !== key)
			.map((n) => (n.children ? { ...n, children: removeTree(n.children, key) } : n));
	}
	function insertChild(list: Section[], parentKey: number, node: Section): Section[] {
		return list.map((n) => {
			if (n.key === parentKey) return { ...n, children: [...(n.children ?? []), node] };
			if (n.children) return { ...n, children: insertChild(n.children, parentKey, node) };
			return n;
		});
	}
	// Is `key` inside the subtree rooted at `ancestorKey`? (prevents dropping a
	// container into itself / its own descendant when moving.)
	function isDescendant(ancestorKey: number, key: number): boolean {
		const a = findNode(sections, ancestorKey);
		return !!(a?.children && findNode(a.children, key));
	}
	// Deep copy with fresh keys (for duplicate).
	function reclone(n: Section): Section {
		const c: Section = {
			...n,
			key: nextKey++,
			values: { ...n.values },
			style: { ...n.style },
			props: n.props ? { ...n.props } : undefined,
			css: n.css ? { ...n.css } : undefined,
			cssMd: n.cssMd ? { ...n.cssMd } : undefined,
			cssSm: n.cssSm ? { ...n.cssSm } : undefined,
		};
		if (n.children) c.children = n.children.map(reclone);
		return c;
	}

	// --- nesting validity ---
	// Components that render an interactive element (an <a> or <button>). HTML
	// forbids nesting interactive content inside interactive content (e.g. <a> in
	// <a>), and the browser silently reparents it — so the inner node "vanishes".
	// We block such drops and lift any already-saved offenders back to top level.
	const INTERACTIVE = new Set(['link', 'button']);
	const isInteractive = (id?: string) => !!id && INTERACTIVE.has(id);
	function subtreeHasInteractive(n: Section): boolean {
		if (isComp(n) && isInteractive(n.comp)) return true;
		// an instance is interactive iff its definition contains interactive content
		if (isInstance(n)) return !!compById(n.ref)?.def.some(subtreeHasInteractive);
		return !!n.children?.some(subtreeHasInteractive);
	}
	// path from a top-level node down to (and including) the node with `key`.
	function findPath(list: Section[], key: number, acc: Section[] = []): Section[] | null {
		for (const n of list) {
			const next = [...acc, n];
			if (n.key === key) return next;
			if (n.children) {
				const p = findPath(n.children, key, next);
				if (p) return p;
			}
		}
		return null;
	}
	// May a node (new comp id, or an existing subtree) be nested into `parentKey`?
	// Interactive children are rejected when any ancestor (incl. the target) is
	// interactive.
	function nestAllowed(parentKey: number, child: string | Section): boolean {
		const childInteractive = typeof child === 'string' ? isInteractive(child) : subtreeHasInteractive(child);
		if (!childInteractive) return true;
		const path = findPath(sections, parentKey) ?? [];
		return !path.some((n) => isComp(n) && isInteractive(n.comp));
	}

	const KEY = 'parascape-designer-v1';
	// A page is a routable document; a project is the page set (LYK-929). The whole
	// project is what persists (localStorage + the server project blob). `nextKey`
	// is a project-global node-key counter so keys stay unique across pages.
	type Doc = { sections: Section[]; codeOverride: string | null };
	// Per-page SEO / social metadata (LYK-947), emitted into the exported /
	// published <svelte:head>.
	type PageMeta = { title?: string; description?: string; image?: string; favicon?: string; lang?: string };
	type Page = { id: number; name: string; route: string; params: string; doc: Doc; meta?: PageMeta };
	// A reusable named component (symbol, LYK-949). `def` is a node tree edited in
	// one place; page nodes reference it by id as instances (`Section.ref`). Lives
	// on the project (shared across pages), not on any one page.
	type NamedComponent = { id: string; name: string; def: Section[] };
	// `data` (LYK-945): inline data sources — named variables/collections bound
	// into node content (Section.bind) + emitted as a `const data = …` in export.
	type Project = { pages: Page[]; activePageId: number; nextKey: number; components: NamedComponent[]; nextCompId: number; data?: Record<string, unknown>; dataUrl?: string };
	type Saved = { sections: Section[]; nextKey?: number; codeOverride?: string | null };
	// Early Designer builds shipped an unprofessional footer default ("for-funzies
	// … Not affiliated with AWS") and later a copyright line. Pages saved then keep
	// it in localStorage and would re-render it over the clean default, so scrub it
	// on load: any persisted field/content matching this gets reset to its section's
	// current default (no copyright, no toy framing).
	const STALE_COPY = /for[-\s]?funzies|not affiliated|for fun\b|©|\(c\)\s*\d|copyright|all rights reserved/i;
	function scrub<T extends { sections: Section[] }>(saved: T): T {
		for (const s of saved.sections ?? []) {
			const def = SECTION_BY_ID[s.type];
			if (s.values) {
				for (const k of Object.keys(s.values)) {
					if (STALE_COPY.test(s.values[k] ?? '')) s.values[k] = def?.defaults[k] ?? '';
				}
			}
			if (s.content && STALE_COPY.test(s.content)) s.content = '';
			// The old stats band shipped a fixed light bg (#f2f3f3) that showed
			// light theme-coloured text on a light surface in dark mode. Migrate it
			// to transparent so contrast follows the theme.
			if (s.type === 'stats' && s.style?.bg === '#f2f3f3') s.style.bg = 'transparent';
		}
		return saved;
	}
	// Repair invalid interactive-in-interactive nesting from older saves (e.g. a
	// Link dropped into a Link before validation existed). Such a child renders
	// nowhere (the browser reparents <a> out of <a>), so lift it back to the top
	// level where it's visible again.
	function fixNesting<T extends { sections: Section[] }>(saved: T): T {
		const lifted: Section[] = [];
		const walk = (list: Section[], ancestorInteractive: boolean): Section[] =>
			list.filter((n) => {
				const selfInteractive = isComp(n) && isInteractive(n.comp);
				if (ancestorInteractive && selfInteractive) {
					if (n.children) n.children = walk(n.children, true);
					lifted.push(n);
					return false;
				}
				if (n.children) n.children = walk(n.children, ancestorInteractive || selfInteractive);
				return true;
			});
		saved.sections = walk(saved.sections ?? [], false);
		if (lifted.length) saved.sections.push(...lifted);
		return saved;
	}
	function starterProject(): Project {
		return {
			pages: [
				{
					id: 1,
					name: 'Home',
					route: '/',
					params: '',
					doc: {
						sections: ['hero', 'features', 'stats', 'cta', 'footer'].map((type, i) => ({
							key: i + 1,
							type,
							values: { ...SECTION_BY_ID[type].defaults },
							style: { ...SECTION_BY_ID[type].style },
						})),
						codeOverride: null,
					},
				},
			],
			activePageId: 1,
			nextKey: 6,
			components: [],
			nextCompId: 1,
		};
	}
	// Normalize any persisted shape into a Project: the current `{ pages }` shape,
	// the legacy single-doc `{ sections, nextKey, codeOverride }` (→ one "Home"
	// page), or junk (→ starter). Each page's doc is scrubbed + nesting-repaired.
	function toProject(o: unknown): Project {
		const x = o as Record<string, unknown>;
		const cleanDoc = (d: unknown): Doc =>
			fixNesting(
				scrub({
					sections: Array.isArray((d as Doc)?.sections) ? (d as Doc).sections : [],
					codeOverride: typeof (d as Doc)?.codeOverride === 'string' ? (d as Doc).codeOverride : null,
				}),
			);
		// Named components (LYK-949). Each def is a node tree → scrub + nesting-repair
		// it like a page's sections.
		const cleanComponents = (v: unknown): NamedComponent[] =>
			Array.isArray(v)
				? (v as NamedComponent[])
						.filter((c) => c && typeof c.id === 'string')
						.map((c) => ({
							id: c.id,
							name: typeof c.name === 'string' && c.name ? c.name : 'Component',
							def: fixNesting(scrub({ sections: Array.isArray(c.def) ? c.def : [] })).sections,
						}))
				: [];
		if (Array.isArray(x?.pages)) {
			const pages: Page[] = (x.pages as Page[]).map((p, i) => ({
				id: typeof p.id === 'number' ? p.id : i + 1,
				name: p.name ?? `Page ${i + 1}`,
				route: p.route ?? '/',
				params: p.params ?? '',
				doc: cleanDoc(p.doc),
					meta: p.meta && typeof p.meta === 'object' ? (p.meta as PageMeta) : undefined,
			}));
			if (!pages.length) return starterProject();
			const activePageId = pages.some((p) => p.id === x.activePageId) ? (x.activePageId as number) : pages[0].id;
			const components = cleanComponents(x.components);
			return {
				pages,
				activePageId,
				nextKey: typeof x.nextKey === 'number' ? x.nextKey : 1,
				components,
				nextCompId: typeof x.nextCompId === 'number' ? x.nextCompId : components.length + 1,
				data: x.data && typeof x.data === 'object' && !Array.isArray(x.data) ? (x.data as Record<string, unknown>) : {},
				dataUrl: typeof x.dataUrl === 'string' ? x.dataUrl : '',
			};
		}
		if (Array.isArray(x?.sections)) {
			return {
				pages: [{ id: 1, name: 'Home', route: '/', params: '', doc: cleanDoc(x) }],
				activePageId: 1,
				nextKey: typeof x.nextKey === 'number' ? x.nextKey : 1,
				components: [],
				nextCompId: 1,
			};
		}
		return starterProject();
	}
	// Corrupt saved state (LYK-941): if the persisted JSON can't be parsed/loaded,
	// keep the raw string so we can offer recovery (download/reset) instead of
	// silently discarding the user's work. Set during loadProject() (pre-signals),
	// surfaced via the `recoverRaw` signal below.
	let corruptRaw: string | null = null;
	function loadProject(): Project {
		let raw: string | null = null;
		try {
			raw = typeof localStorage !== 'undefined' ? localStorage.getItem(KEY) : null;
		} catch {
			return starterProject();
		}
		if (!raw) return starterProject();
		try {
			return toProject(JSON.parse(raw));
		} catch {
			corruptRaw = raw; // unparseable → recover, don't silently reset
			return starterProject();
		}
	}
	const init = loadProject();
	let nextKey = init.nextKey;
	let nextPageId = Math.max(0, ...init.pages.map((p) => p.id)) + 1;
	signal pages: Page[] = init.pages;
	signal activePageId = init.activePageId;
	// LYK-945: inline data sources, edited as JSON; bound into node content.
	signal siteData: Record<string, unknown> = init.data ?? {};
	signal dataText = JSON.stringify(init.data ?? {}, null, 2);
	signal dataError: string | null = null;
	const setDataText = (t: string) => {
		dataText = t;
		try {
			const v = JSON.parse(t || '{}');
			if (v == null || typeof v !== 'object' || Array.isArray(v)) {
				dataError = 'Data must be a JSON object';
				return;
			}
			siteData = v as Record<string, unknown>;
			dataError = null;
		} catch {
			dataError = 'Invalid JSON';
		}
	};
	// LYK-945: optional live data source — a CMS/API URL. The Designer fetches it
	// to preview against real data; the export emits a runtime fetch (see dataDecl).
	signal dataUrl = init.dataUrl ?? '';
	signal dataLoading = false;
	async function loadDataUrl() {
		const url = dataUrl.trim();
		if (!url || dataLoading) return;
		dataLoading = true;
		dataError = null;
		try {
			const d = await (await fetch(url)).json();
			if (d == null || typeof d !== 'object' || Array.isArray(d)) throw new Error('not an object');
			siteData = d as Record<string, unknown>;
			dataText = JSON.stringify(d, null, 2);
		} catch {
			dataError = 'Could not fetch / parse that URL';
		} finally {
			dataLoading = false;
		}
	}
	const _initActive = init.pages.find((p) => p.id === init.activePageId) ?? init.pages[0];
	signal sections: Section[] = _initActive.doc.sections;

	// --- reusable named components / symbols (LYK-949) ---
	signal components: NamedComponent[] = init.components;
	let nextCompId = init.nextCompId;
	const compById = (id?: string): NamedComponent | undefined => (id ? components.find((c) => c.id === id) : undefined);
	// Internal editing: while a symbol is open, `sections` holds its def and the
	// page's own sections are stashed here; currentProject() routes persistence to
	// the right place and exitComponentEdit() writes the edited def back.
	signal editingComponentId: string | null = null;
	let pageSectionsStash: Section[] | null = null;
	let pageCodeStash: string | null = null;
	derived editingComponent = editingComponentId ? compById(editingComponentId) : null;

	signal selectedKey: number | null = null;
	signal device = 'desktop';
	// canvas zoom (LYK-938): scale the artboard 25%–200%; 1 = 100%.
	signal zoom = 1;
	const setZoom = (z: number) => (zoom = Math.min(2, Math.max(0.25, Math.round(z * 20) / 20)));
	signal showExport = false;
	// Code Mode (VS.NET-style): the raw .pui is canonical. While `codeOverride`
	// is set, the canvas renders it (the visual is a representation of the code)
	// and it's what exports; the visual blocks are paused until "Revert to visual"
	// clears it. `codeMode` is the editor view; `codeDraft` is the editor buffer.
	signal codeOverride: string | null = _initActive.doc.codeOverride ?? null;
	signal codeMode = false;
	signal codeDraft = '';
	signal codeErr: string | null = null;
	// Code Mode diagnostics + autocomplete (LYK-939)
	signal codeErrLine: number | null = null;
	signal codeCaret = 0;
	// syntax-highlighted editor overlay (textarea over a Shiki <pre>)
	signal codeScrollY = 0;
	signal hlReady = false;
	effect {
		shikiReady.then(() => (hlReady = true));
	}
	derived codeHighlighted {
		hlReady; // re-highlight once the highlighter finishes init
		return highlightSync(codeDraft, 'pui');
	}
	derived codeLineNos = codeDraft.split('\n').map((_, i) => i + 1).join('\n');
	// add-panel tab: 'sections' | 'components'
	signal addTab = 'sections';
	signal compSearch = '';
	// AI generation (LYK-936, folded in from the Builder). POSTs a prompt to the
	// optional ParaBun llm-server (builder/llm-server.ts) and drops the returned
	// .pui into Code Mode as the page's canonical source.
	const AI_ENDPOINT = 'http://localhost:8787';
	signal aiPrompt = '';
	signal aiBusy = false;
	signal aiError: string | null = null;
	// command palette (LYK-942)
	signal showPalette = false;
	signal paletteQuery = '';
	signal paletteIndex = 0;
	// corrupt-state recovery (LYK-941): the raw saved string when it failed to load
	signal recoverRaw: string | null = corruptRaw;
	// media library (LYK-935): uploaded images, stored server-side in SQLite.
	signal assets: AssetMeta[] = [];
	signal assetErr: string | null = null;
	// version history (LYK-943): server-backed named snapshots
	signal snapshots: account.SnapshotMeta[] = [];
	signal historyBusy = false;
	// publish / dev preview (LYK-934)
	signal publishBusy = false;
	signal publishUrl: string | null = null;
	// drag state. dropIndex is the 0..sections.length insert position. A drag is
	// either a reorder of an existing section (dragKey) or a new item being drawn
	// in from the palette (dragNew); both compute dropIndex the same way.
	signal dragKey: number | null = null;
	signal dragNew: { kind: 'section' | 'component' | 'instance'; id: string } | null = null;
	signal dropIndex: number | null = null;
	// when hovering a container component's body, the drop nests inside it instead
	// of inserting between top-level sections.
	signal nestKey: number | null = null;
	// export view: hovering a code segment highlights its section in the canvas.
	signal hoverKey: number | null = null;
	// in-place editing: the section whose text is currently being edited (its
	// drag is suspended while editing so the caret/selection works).
	signal editingKey: number | null = null;
	// Account + server persistence (LYK-930). When signed in, the page doc is
	// saved to the user's project in SQLite (debounced); signed out, it's the
	// localStorage-only behaviour. `saveState` drives the toolbar indicator.
	signal acct: Account | null = null;
	// Guest mode (the desktop / Tauri build): server runs single-user, the account
	// UI is hidden, and persistence happens silently as the built-in guest.
	signal guest = false;
	signal projectId: number | null = null;
	signal saveState: 'offline' | 'saving' | 'saved' | 'error' = 'offline';
	// Real-time collaboration (LYK-944). When signed in on a server-backed project,
	// `collab` mirrors the project into a CRDT shared with other editors of the same
	// project over a WebSocket; `collabPeers` are the others' live presence (cursors
	// + names), `collabLive` is the connection state. `applyingRemote` guards the
	// autosave→push path so an inbound change isn't immediately echoed back.
	let collab: ReturnType<typeof createCollab> | null = null;
	let applyingRemote = false;
	signal collabPeers: Presence[] = [];
	signal collabLive = false;
	signal showAuth = false;
	signal authMode: 'login' | 'register' = 'login';
	signal authUser = '';
	signal authPass = '';
	signal authErr = '';
	signal authBusy = false;
	// Accessibility check (LYK-931): runs real axe-core over the rendered page.
	signal showA11y = false;
	signal a11yScanning = false;
	signal a11yResults: { impact: string; id: string; help: string; helpUrl: string; count: number; target: string }[] | null = null;

	const defOf = (s: Section) => SECTION_BY_ID[s.type];
	const labelOf = (s: Section) =>
		isInstance(s) ? compById(s.ref)?.name ?? 'Component' : isFree(s) ? 'Free canvas' : isRepeat(s) ? 'Repeater' : isComp(s) ? displayName(s.comp!) : defOf(s)?.name ?? s.type;
	// true when this section, or any node nested inside it, is the selection.
	const inSel = (s: Section) => selectedKey !== null && !!findNode([s], selectedKey);
	derived selected = selectedKey === null ? null : findNode(sections, selectedKey);
	derived activePage = pages.find((p) => p.id === activePageId) ?? pages[0];
	derived filteredComponents {
		const q = compSearch.trim().toLowerCase();
		if (!q) return allComponents;
		return allComponents.filter((c) => c.name.toLowerCase().includes(q) || c.id.includes(q));
	}

	// the active page's live doc (the editor edits sections/codeOverride directly;
	// they're folded back into `pages` here for persistence).
	// While a symbol is open, the live `sections` is its def, not the page's — so
	// the page's sections come from the stash and the def is folded back into
	// `components`. When not editing, behaves as before.
	const pageSecsNow = (): Section[] => (editingComponentId ? pageSectionsStash ?? [] : sections);
	const componentsNow = (): NamedComponent[] =>
		editingComponentId ? components.map((c) => (c.id === editingComponentId ? { ...c, def: clone(sections) } : c)) : components;
	const activeDoc = (): Doc => ({ sections: clone(pageSecsNow()), codeOverride: editingComponentId ? pageCodeStash : codeOverride });
	function currentProject(): Project {
		return {
			pages: pages.map((p) => (p.id === activePageId ? { ...p, doc: activeDoc() } : p)),
			activePageId,
			nextKey,
			components: clone(componentsNow()),
			nextCompId,
			data: siteData,
			dataUrl: dataUrl || undefined,
		};
	}
	effect {
		// persist the whole project (all pages + components) to localStorage
		const _s = sections,
			_c = codeOverride,
			_p = pages,
			_a = activePageId,
			_cm = components,
			_e = editingComponentId,
			_d = siteData,
			_du = dataUrl; // track
		try {
			localStorage.setItem(KEY, JSON.stringify(currentProject()));
		} catch {}
	}

	// --- undo / redo (LYK-926) ---
	// A snapshot history of the whole editable state. Every mutation reassigns the
	// `sections`/`codeOverride` signals, so a single effect that tracks them records
	// a new snapshot; `nextKey` + the history arrays are read under untrack() so they
	// don't become dependencies (which would loop). JSON-dedup means an undo-restore
	// (which re-sets the signals to a prior snapshot) doesn't get re-recorded.
	// JSON deep-clone (structuredClone can't clone Svelte 5 reactive proxies; the
	// node tree is fully JSON-serializable).
	const clone = <T>(x: T): T => JSON.parse(JSON.stringify(x)) as T;
	type Snap = { sections: Section[]; nextKey: number; codeOverride: string | null };
	signal hist: Snap[] = [];
	signal histJson: string[] = [];
	signal hcursor = -1;
	derived canUndo = hcursor > 0;
	derived canRedo = hcursor >= 0 && hcursor < hist.length - 1;
	effect {
		const s = sections; // track
		const c = codeOverride; // track
		untrack(() => {
			const json = JSON.stringify([s, nextKey, c]);
			if (histJson[hcursor] === json) return; // unchanged (e.g. from an undo/redo restore)
			const snap: Snap = { sections: clone(s), nextKey, codeOverride: c };
			let h = [...hist.slice(0, hcursor + 1), snap];
			let hj = [...histJson.slice(0, hcursor + 1), json];
			if (h.length > 100) {
				h = h.slice(-100);
				hj = hj.slice(-100);
			}
			hist = h;
			histJson = hj;
			hcursor = h.length - 1;
		});
	}
	function applySnap(snap: Snap) {
		sections = clone(snap.sections);
		nextKey = snap.nextKey;
		codeOverride = snap.codeOverride;
	}
	function undo() {
		if (hcursor <= 0) return;
		hcursor = hcursor - 1;
		applySnap(hist[hcursor]);
	}
	function redo() {
		if (hcursor >= hist.length - 1) return;
		hcursor = hcursor + 1;
		applySnap(hist[hcursor]);
	}
	function resetHistory() {
		hist = [];
		histJson = [];
		hcursor = -1;
	}

	// --- pages / routing (LYK-929) ---
	function loadPageDoc(doc: Doc) {
		sections = clone(doc.sections);
		codeOverride = doc.codeOverride;
		nextKey = Math.max(nextKey, maxKeyOf(sections) + 1);
		selectedKey = null;
		showExport = false;
		showA11y = false;
		codeMode = false;
		resetHistory();
	}
	function switchPage(id: number) {
		if (id === activePageId) return;
		pages = pages.map((p) => (p.id === activePageId ? { ...p, doc: activeDoc() } : p));
		activePageId = id;
		const np = pages.find((p) => p.id === id);
		if (np) loadPageDoc(np.doc);
	}
	function addPage() {
		const n = pages.length + 1;
		pages = pages.map((p) => (p.id === activePageId ? { ...p, doc: activeDoc() } : p));
		const id = nextPageId++;
		const page: Page = { id, name: `Page ${n}`, route: `/page-${n}`, params: '', doc: { sections: [], codeOverride: null } };
		pages = [...pages, page];
		activePageId = id;
		loadPageDoc(page.doc);
	}
	function deletePage(id: number) {
		if (pages.length <= 1) return;
		const remaining = pages.filter((p) => p.id !== id);
		pages = remaining;
		if (activePageId === id) {
			activePageId = remaining[0].id;
			loadPageDoc(remaining[0].doc);
		}
	}
	const renamePage = (id: number, name: string) => (pages = pages.map((p) => (p.id === id ? { ...p, name } : p)));
	const setRoute = (id: number, route: string) => (pages = pages.map((p) => (p.id === id ? { ...p, route } : p)));
	const setParams = (id: number, params: string) => (pages = pages.map((p) => (p.id === id ? { ...p, params } : p)));
	const setMeta = (id: number, patch: Partial<PageMeta>) =>
		(pages = pages.map((p) => (p.id === id ? { ...p, meta: { ...p.meta, ...patch } } : p)));

	// --- named components / symbols (LYK-949) ---
	// PascalCase identifier from a display name (for the exported tag / module).
	const compIdent = (name: string): string => {
		const id = name
			.replace(/[^a-zA-Z0-9]+/g, ' ')
			.trim()
			.split(' ')
			.filter(Boolean)
			.map((w) => w[0].toUpperCase() + w.slice(1))
			.join('');
		return /^[A-Za-z]/.test(id) ? id : 'C' + (id || 'omponent');
	};
	// Unique identifier per component (export imports/tags can't collide on name).
	derived identByComp {
		const used = new Set<string>();
		const map: Record<string, string> = {};
		for (const c of components) {
			const base = compIdent(c.name);
			let id = base;
			let n = 2;
			while (used.has(id)) id = base + n++;
			used.add(id);
			map[c.id] = id;
		}
		return map;
	}
	function makeInstance(refId: string): Section {
		return {
			key: nextKey++,
			type: 'instance',
			ref: refId,
			values: {},
			style: { bg: 'transparent', fg: 'inherit', padY: 40, align: 'center', width: 1040 },
		};
	}
	// Does `def` reference component `id` (directly or transitively)? Recursion
	// guard so a component can't contain an instance of itself.
	function defReferences(def: Section[], id: string, seen = new Set<string>()): boolean {
		const walk = (list: Section[]): boolean =>
			list.some((n) => {
				if (isInstance(n) && n.ref) {
					if (n.ref === id) return true;
					if (!seen.has(n.ref)) {
						seen.add(n.ref);
						const c = compById(n.ref);
						if (c && walk(c.def)) return true;
					}
				}
				return n.children ? walk(n.children) : false;
			});
		return walk(def);
	}
	// Turn the current selection into a new named component; the selected node
	// becomes the first instance of it.
	function createComponentFromSelection() {
		if (selectedKey === null) return;
		const node = findNode(sections, selectedKey);
		if (!node) return;
		const name = (prompt('Name this component', 'My component') ?? '').trim();
		if (!name) return;
		const id = 'c' + nextCompId++;
		components = [...components, { id, name, def: [reclone(node)] }];
		const inst = makeInstance(id);
		sections = mapTree(sections, selectedKey, () => inst);
		selectedKey = inst.key;
		showExport = false;
	}
	// May an instance of `compId` be added to the current canvas? Blocks recursion
	// while editing a component (a component can't contain itself, directly or via
	// another component that references it back).
	const instanceAllowed = (compId: string): boolean =>
		!editingComponentId || (compId !== editingComponentId && !defReferences(compById(compId)?.def ?? [], editingComponentId));
	function addInstance(compId: string) {
		if (!instanceAllowed(compId)) return;
		insertSection(makeInstance(compId), sections.length);
	}
	// Open a component for internal editing: stash the page, swap `sections` to the
	// component's def. "Done" writes the def back so every instance updates.
	function enterComponentEdit(id: string) {
		if (editingComponentId === id) return;
		if (editingComponentId) exitComponentEdit();
		const c = compById(id);
		if (!c) return;
		pageSectionsStash = clone(sections);
		pageCodeStash = codeOverride;
		editingComponentId = id;
		sections = clone(c.def);
		codeOverride = null;
		selectedKey = null;
		showExport = false;
		showA11y = false;
		codeMode = false;
		resetHistory();
	}
	function exitComponentEdit() {
		if (!editingComponentId) return;
		const id = editingComponentId;
		const def = clone(sections);
		components = components.map((c) => (c.id === id ? { ...c, def } : c));
		editingComponentId = null;
		sections = pageSectionsStash ?? [];
		codeOverride = pageCodeStash;
		pageSectionsStash = null;
		pageCodeStash = null;
		selectedKey = null;
		showExport = false;
		resetHistory();
	}
	const renameComponent = (id: string, name: string) =>
		(components = components.map((c) => (c.id === id ? { ...c, name } : c)));
	// Delete a component, detaching every instance across the whole project by
	// inlining its def in place (so the rendered content is preserved, not lost).
	function deleteComponent(id: string) {
		const c = compById(id);
		if (!c) return;
		const count = instanceCount(id);
		if (count && !confirm(`"${c.name}" has ${count} instance${count === 1 ? '' : 's'}. Delete it and detach them (keep their content)?`)) return;
		const inline = (list: Section[]): Section[] =>
			list.flatMap((n) => {
				if (isInstance(n) && n.ref === id) return c.def.map(reclone);
				if (n.children) return [{ ...n, children: inline(n.children) }];
				return [n];
			});
		if (editingComponentId === id) exitComponentEdit();
		if (pageSectionsStash) pageSectionsStash = inline(pageSectionsStash);
		sections = inline(sections);
		pages = pages.map((p) => ({ ...p, doc: { ...p.doc, sections: inline(p.doc.sections) } }));
		components = components.filter((x) => x.id !== id).map((x) => ({ ...x, def: inline(x.def) }));
	}
	// Count live instances of a component across the page, the stashed page, all
	// pages' docs, and other components' defs.
	function instanceCount(id: string): number {
		const walk = (list: Section[]): number =>
			list.reduce((acc, n) => acc + (isInstance(n) && n.ref === id ? 1 : 0) + (n.children ? walk(n.children) : 0), 0);
		let total = walk(editingComponentId ? pageSectionsStash ?? [] : sections);
		for (const p of pages) if (p.id !== activePageId) total += walk(p.doc.sections);
		for (const c of components) if (c.id !== id) total += walk(c.def);
		return total;
	}

	// --- free canvas (LYK-936): Builder-style absolute placement of a free
	// section's direct children, with pointer drag + resize + snap-to-grid. ---
	const GRID = 8;
	const MINSZ = 24;
	const snapG = (v: number) => Math.max(0, Math.round(v / GRID) * GRID);
	function makeFreeSection(): Section {
		return {
			key: nextKey++,
			type: 'free',
			values: {},
			style: { bg: 'transparent', fg: 'inherit', padY: 24, align: 'left', width: 0 },
			children: [],
		};
	}
	const addFreeSection = () => insertSection(makeFreeSection(), sections.length);
	let fdrag: { key: number; ox: number; oy: number; sx: number; sy: number } | null = null;
	let fresize: { key: number; ow: number; oh: number; sx: number; sy: number } | null = null;
	function startFDrag(e: PointerEvent, c: Section) {
		if ((e.target as HTMLElement).closest('.fresize')) return;
		e.stopPropagation();
		e.preventDefault();
		selectedKey = c.key;
		showExport = false;
		fdrag = { key: c.key, ox: c.x ?? 24, oy: c.y ?? 24, sx: e.clientX, sy: e.clientY };
		window.addEventListener('pointermove', onFDrag);
		window.addEventListener('pointerup', endFDrag);
	}
	function onFDrag(e: PointerEvent) {
		if (!fdrag) return;
		// divide by zoom so a screen-space drag maps to canvas-space movement
		const x = snapG(fdrag.ox + (e.clientX - fdrag.sx) / zoom);
		const y = snapG(fdrag.oy + (e.clientY - fdrag.sy) / zoom);
		sections = mapTree(sections, fdrag.key, (n) => ({ ...n, x, y }));
	}
	function endFDrag() {
		fdrag = null;
		window.removeEventListener('pointermove', onFDrag);
		window.removeEventListener('pointerup', endFDrag);
	}
	function startFResize(e: PointerEvent, c: Section) {
		e.stopPropagation();
		e.preventDefault();
		selectedKey = c.key;
		const el = (e.currentTarget as HTMLElement).closest('.fnode') as HTMLElement;
		fresize = { key: c.key, ow: c.w ?? el.offsetWidth, oh: c.h ?? el.offsetHeight, sx: e.clientX, sy: e.clientY };
		window.addEventListener('pointermove', onFResize);
		window.addEventListener('pointerup', endFResize);
	}
	function onFResize(e: PointerEvent) {
		if (!fresize) return;
		const w = Math.max(MINSZ, snapG(fresize.ow + (e.clientX - fresize.sx) / zoom));
		const h = Math.max(MINSZ, snapG(fresize.oh + (e.clientY - fresize.sy) / zoom));
		sections = mapTree(sections, fresize.key, (n) => ({ ...n, w, h }));
	}
	function endFResize() {
		fresize = null;
		window.removeEventListener('pointermove', onFResize);
		window.removeEventListener('pointerup', endFResize);
	}

	// --- templates / starter library (LYK-937) ---
	// A template's section specs → real Section nodes with fresh keys.
	function templateSections(t: Template): Section[] {
		const fallback = { bg: 'transparent', fg: 'inherit', padY: 40, align: 'center', width: 1040 } as SectionStyle;
		return t.sections.map((spec) => ({
			key: nextKey++,
			type: spec.type,
			values: { ...(SECTION_BY_ID[spec.type]?.defaults ?? {}), ...(spec.values ?? {}) },
			style: { ...(SECTION_BY_ID[spec.type]?.style ?? fallback), ...(spec.style ?? {}) },
		}));
	}
	// Insert a template's section group into the current page.
	function insertTemplate(t: Template) {
		const group = templateSections(t);
		if (!group.length) return;
		sections = [...sections, ...group];
		selectedKey = group[0].key;
		showExport = false;
	}
	// Create a new page from a template.
	function newPageFromTemplate(t: Template) {
		if (editingComponentId) exitComponentEdit();
		const n = pages.length + 1;
		pages = pages.map((p) => (p.id === activePageId ? { ...p, doc: activeDoc() } : p));
		const id = nextPageId++;
		const route = t.id === 'blank' ? `/page-${n}` : `/${t.id}-${n}`;
		const page: Page = { id, name: t.name, route, params: '', doc: { sections: templateSections(t), codeOverride: null } };
		pages = [...pages, page];
		activePageId = id;
		loadPageDoc(page.doc);
	}

	// --- command palette (LYK-942) ---
	type PaletteItem = { key: string; label: string; group: string; run: () => void };
	function openPalette() {
		showPalette = true;
		paletteQuery = '';
		paletteIndex = 0;
	}
	// One flat, fuzzy-searchable list of everything you can do: actions, plus
	// add-section / insert-template / add-component commands.
	derived paletteItems {
		const q = paletteQuery.trim().toLowerCase();
		const all: PaletteItem[] = [];
		const actions: { label: string; run: () => void }[] = [
			{ label: 'Undo', run: undo },
			{ label: 'Redo', run: redo },
			{ label: 'Toggle Code Mode', run: toggleCode },
			{ label: 'Accessibility check', run: toggleA11y },
			{ label: 'Export .pui', run: () => { showExport = true; showA11y = false; selectedKey = null; } },
			{ label: 'New page', run: addPage },
			{ label: 'Clear page', run: clearAll },
		];
		for (const a of actions) all.push({ key: 'a:' + a.label, label: a.label, group: 'Action', run: a.run });
		all.push({ key: 's:free', label: 'Add Free canvas', group: 'Section', run: addFreeSection });
		all.push({ key: 's:repeat', label: 'Add Repeater (data list)', group: 'Section', run: addRepeat });
		for (const def of SECTIONS) all.push({ key: 's:' + def.id, label: 'Add section: ' + def.name, group: 'Section', run: () => addSection(def.id) });
		for (const t of TEMPLATES) all.push({ key: 't:' + t.id, label: 'Template: ' + t.name, group: 'Template', run: () => insertTemplate(t) });
		for (const c of allComponents) all.push({ key: 'c:' + c.id, label: 'Add component: ' + c.name, group: 'Component', run: () => addComponent(c.id) });
		const out = q ? all.filter((i) => i.label.toLowerCase().includes(q)) : all.slice(0, 30);
		return out.slice(0, 80);
	}
	function runPalette(i: PaletteItem) {
		showPalette = false;
		paletteQuery = '';
		i.run();
	}
	function paletteKey(e: KeyboardEvent) {
		const items = paletteItems;
		if (e.key === 'ArrowDown') {
			e.preventDefault();
			paletteIndex = Math.min(paletteIndex + 1, items.length - 1);
		} else if (e.key === 'ArrowUp') {
			e.preventDefault();
			paletteIndex = Math.max(paletteIndex - 1, 0);
		} else if (e.key === 'Enter') {
			e.preventDefault();
			const it = items[paletteIndex];
			if (it) runPalette(it);
		} else if (e.key === 'Escape') {
			e.preventDefault();
			showPalette = false;
		}
	}

	// --- corrupt-state recovery (LYK-941) ---
	function downloadRecover() {
		if (!recoverRaw) return;
		const blob = new Blob([recoverRaw], { type: 'application/json' });
		const url = URL.createObjectURL(blob);
		const a = document.createElement('a');
		a.href = url;
		a.download = 'parascape-recovery.json';
		a.click();
		URL.revokeObjectURL(url);
	}
	const dismissRecover = () => (recoverRaw = null);

	// --- keyboard shortcuts + clipboard (LYK-928) ---
	let clipboard: Section | null = null;
	const isEditableTarget = (t: EventTarget | null) => {
		const el = t as HTMLElement | null;
		return !!el && (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA' || el.isContentEditable);
	};
	function onGlobalKey(e: KeyboardEvent) {
		const mod = e.metaKey || e.ctrlKey;
		// command palette (LYK-942) — opens even when focus is in an input
		if (mod && (e.key === 'k' || e.key === 'K')) {
			e.preventDefault();
			openPalette();
			return;
		}
		// let inputs / the code editor / inline-edit handle their own keys
		if (isEditableTarget(e.target)) return;
		if (mod && (e.key === 'z' || e.key === 'Z')) {
			e.preventDefault();
			e.shiftKey ? redo() : undo();
			return;
		}
		if (mod && (e.key === 'y' || e.key === 'Y')) {
			e.preventDefault();
			redo();
			return;
		}
		if (mod && (e.key === 's' || e.key === 'S')) {
			e.preventDefault(); // already autosaves
			return;
		}
		// canvas zoom (LYK-938): ⌘+ / ⌘- / ⌘0
		if (mod && (e.key === '=' || e.key === '+')) {
			e.preventDefault();
			setZoom(zoom + 0.1);
			return;
		}
		if (mod && e.key === '-') {
			e.preventDefault();
			setZoom(zoom - 0.1);
			return;
		}
		if (mod && e.key === '0') {
			e.preventDefault();
			zoom = 1;
			return;
		}
		if (e.key === 'Escape') {
			selectedKey = null;
			return;
		}
		if (selectedKey === null) return;
		if (e.key === 'Delete' || e.key === 'Backspace') {
			e.preventDefault();
			removeSection(selectedKey);
			return;
		}
		if (mod && (e.key === 'd' || e.key === 'D')) {
			e.preventDefault();
			duplicate(selectedKey);
			return;
		}
		if (mod && (e.key === 'c' || e.key === 'C')) {
			const n = findNode(sections, selectedKey);
			if (n) clipboard = clone(n);
			return;
		}
		if (mod && (e.key === 'v' || e.key === 'V')) {
			if (!clipboard) return;
			e.preventDefault();
			const copy = reclone(clipboard);
			const sel = findNode(sections, selectedKey);
			if (sel && isContainer(sel) && nestAllowed(sel.key, copy)) sections = insertChild(sections, sel.key, copy);
			else sections = [...sections, copy];
			selectedKey = copy.key;
		}
	}

	// Build a section/component without placing it (used by both click-to-append
	// and drag-from-palette-to-position).
	function makeSection(type: string): Section {
		const def = SECTION_BY_ID[type];
		return { key: nextKey++, type, values: { ...def.defaults }, style: { ...def.style } };
	}
	function makeComponent(id: string): Section {
		const sd = seed[id] ?? {};
		return {
			key: nextKey++,
			type: 'component',
			comp: id,
			props: { ...(sd.props ?? {}) },
			content: sd.content ?? (takesContent(id) ? displayName(id) : ''),
			values: {},
			style: { bg: 'transparent', fg: 'inherit', padY: 40, align: 'center', width: 1040 },
		};
	}
	function insertSection(s: Section, at: number) {
		const i = Math.max(0, Math.min(at, sections.length));
		sections = [...sections.slice(0, i), s, ...sections.slice(i)];
		selectedKey = s.key;
		showExport = false;
	}
	// Click a palette item → append to the end. Dragging it places it precisely.
	function addSection(type: string) {
		insertSection(makeSection(type), sections.length);
	}
	function addComponent(id: string) {
		insertSection(makeComponent(id), sections.length);
	}
	// LYK-945: a repeater node — a container whose children are the row template.
	function makeRepeat(): Section {
		return {
			key: nextKey++,
			type: 'repeat',
			source: '',
			values: {},
			children: [],
			style: { bg: 'transparent', fg: 'inherit', padY: 24, align: 'left', width: 1040 },
		};
	}
	function addRepeat() {
		insertSection(makeRepeat(), sections.length);
	}
	function setSource(key: number, source: string) {
		sections = mapTree(sections, key, (s) => ({ ...s, source }));
	}
	function setProp(key: number, name: string, value: string | number | boolean) {
		sections = mapTree(sections, key, (s) => ({ ...s, props: { ...(s.props ?? {}), [name]: value } }));
	}
	function setContent(key: number, value: string) {
		sections = mapTree(sections, key, (s) => ({ ...s, content: value }));
	}
	// LYK-945: bind/unbind a node's content to a data path.
	function setBind(key: number, path: string) {
		sections = mapTree(sections, key, (s) => ({ ...s, bind: path || undefined }));
	}
	// LYK-945: bind/unbind a single prop to a data path.
	function setPropBind(key: number, prop: string, path: string) {
		sections = mapTree(sections, key, (s) => {
			const pb = { ...(s.propBind ?? {}) };
			if (path) pb[prop] = path;
			else delete pb[prop];
			return { ...s, propBind: Object.keys(pb).length ? pb : undefined };
		});
	}
	function removeSection(key: number) {
		sections = removeTree(sections, key);
		if (selectedKey === key) selectedKey = null;
	}
	function duplicate(key: number) {
		// Only top-level nodes carry the duplicate control; copy as the next sibling.
		const i = sections.findIndex((s) => s.key === key);
		if (i < 0) return;
		const copy = reclone(sections[i]);
		sections = [...sections.slice(0, i + 1), copy, ...sections.slice(i + 1)];
		selectedKey = copy.key;
	}
	function move(key: number, dir: -1 | 1) {
		const i = sections.findIndex((s) => s.key === key);
		const j = i + dir;
		if (i < 0 || j < 0 || j >= sections.length) return;
		const next = sections.slice();
		[next[i], next[j]] = [next[j], next[i]];
		sections = next;
	}
	// HTML5 DnD. Two drag sources, one drop target (the canvas):
	//  • an existing section being reordered  → onDragStart sets dragKey
	//  • a palette item being drawn in        → onPaletteDragStart sets dragNew
	// onCanvasDragOver computes the insert position from the cursor's Y vs each
	// section's midpoint; onCanvasDrop either moves the section or inserts a new
	// one at dropIndex.
	function onDragStart(e: DragEvent, key: number) {
		dragKey = key;
		dragNew = null;
		selectedKey = key;
		if (e.dataTransfer) {
			e.dataTransfer.effectAllowed = 'move';
			e.dataTransfer.setData('text/plain', String(key));
		}
	}
	function onPaletteDragStart(e: DragEvent, kind: 'section' | 'component' | 'instance', id: string) {
		dragNew = { kind, id };
		dragKey = null;
		if (e.dataTransfer) {
			e.dataTransfer.effectAllowed = 'copy';
			e.dataTransfer.setData('text/plain', id);
		}
	}
	function highlightNest(el: HTMLElement | null) {
		for (const d of document.querySelectorAll('.pdrop.nest-over')) d.classList.remove('nest-over');
		el?.classList.add('nest-over');
	}
	// what's being dragged (a palette comp id, an instance's synthetic node, or the
	// moving node's subtree). Instances become a synthetic node so the nesting-
	// validity check can resolve their definition's interactivity.
	const draggedDescriptor = (): string | Section | null =>
		dragNew
			? dragNew.kind === 'instance'
				? ({ key: -1, type: 'instance', ref: dragNew.id, values: {}, style: {} as SectionStyle } as Section)
				: dragNew.id
			: dragKey !== null
				? findNode(sections, dragKey)
				: null;
	// Walk the drop-zone ancestor chain under the cursor and return the INNERMOST
	// one the dragged node may nest into. This skips zones that would be invalid
	// (e.g. an existing Link inside a Container) and falls through to the Container
	// — so "add a Link beside an existing Link in a Container" works.
	function validDropZone(over: HTMLElement | null, child: string | Section): HTMLElement | null {
		let node: HTMLElement | null = over;
		while (node) {
			const dz = node.closest?.('.pdrop[data-drop]') as HTMLElement | null;
			if (!dz) return null;
			const k = Number(dz.getAttribute('data-drop'));
			const selfDrop = dragKey !== null && (k === dragKey || isDescendant(dragKey, k));
			if (!selfDrop && nestAllowed(k, child)) return dz;
			node = dz.parentElement; // keep searching outward
		}
		return null;
	}
	function onCanvasDragOver(e: DragEvent) {
		if (dragKey === null && dragNew === null) return;
		e.preventDefault();
		if (e.dataTransfer) e.dataTransfer.dropEffect = dragNew ? 'copy' : 'move';
		const child = draggedDescriptor();
		const over = document.elementFromPoint(e.clientX, e.clientY) as HTMLElement | null;
		const drop = child !== null ? validDropZone(over, child) : null;
		if (drop) {
			nestKey = Number(drop.getAttribute('data-drop'));
			dropIndex = null;
			highlightNest(drop);
			return;
		}
		// no valid container under the cursor → insert into the top-level stack
		nestKey = null;
		highlightNest(null);
		const secs = Array.from((e.currentTarget as HTMLElement).querySelectorAll('.sec')) as HTMLElement[];
		let idx = secs.length;
		for (let i = 0; i < secs.length; i++) {
			const r = secs[i].getBoundingClientRect();
			if (e.clientY < r.top + r.height / 2) {
				idx = i;
				break;
			}
		}
		dropIndex = idx;
	}
	function onCanvasDrop(e: DragEvent) {
		if (nestKey === null && dropIndex === null) {
			onDragEnd();
			return;
		}
		e.preventDefault();
		if (dragNew) {
			if (dragNew.kind === 'instance' && !instanceAllowed(dragNew.id)) {
				onDragEnd();
				return;
			}
			const node =
				dragNew.kind === 'section'
					? makeSection(dragNew.id)
					: dragNew.kind === 'instance'
						? makeInstance(dragNew.id)
						: makeComponent(dragNew.id);
			if (nestKey !== null) {
				const tgt = findNode(sections, nestKey);
				if (tgt && isFree(tgt)) {
					const i = tgt.children?.length ?? 0;
					node.x = 24 + (i % 6) * 24;
					node.y = 24 + (i % 6) * 24;
				}
				sections = insertChild(sections, nestKey, node);
				selectedKey = node.key;
				showExport = false;
			} else if (dropIndex !== null) {
				insertSection(node, dropIndex);
			}
		} else if (dragKey !== null) {
			const node = findNode(sections, dragKey);
			if (node && nestKey !== null && nestKey !== dragKey && !isDescendant(dragKey, nestKey)) {
				// move an existing node into a container
				sections = insertChild(removeTree(sections, dragKey), nestKey, node);
				selectedKey = node.key;
			} else if (node && dropIndex !== null) {
				// reorder / promote to the top-level stack at dropIndex
				const wasTop = sections.some((s) => s.key === dragKey);
				const oldIdx = sections.findIndex((s) => s.key === dragKey);
				const rest = removeTree(sections, dragKey);
				let to = dropIndex;
				if (wasTop && oldIdx >= 0 && oldIdx < to) to--; // removal shifted the tail left
				sections = [...rest.slice(0, to), node, ...rest.slice(to)];
				selectedKey = node.key;
			}
		}
		onDragEnd();
	}
	function onDragEnd() {
		dragKey = null;
		dragNew = null;
		dropIndex = null;
		nestKey = null;
		highlightNest(null);
	}

	function setValue(key: number, field: string, value: string) {
		sections = mapTree(sections, key, (s) => ({ ...s, values: { ...s.values, [field]: value } }));
	}

	// Click in the preview selects the nearest node (a nested component via its
	// data-pk wrapper, else the top-level section). Previewed links/buttons are
	// inert in the editor, so suppress their default action.
	function selectFromClick(e: MouseEvent, s: Section) {
		const t = e.target as HTMLElement | null;
		if (t?.closest?.('a[href], button')) e.preventDefault();
		const pk = t?.closest?.('[data-pk]') as HTMLElement | null;
		selectedKey = pk ? Number(pk.getAttribute('data-pk')) : s.key;
		showExport = false;
	}

	// Double-click any text in the preview to edit it in place. The preview wraps
	// each editable value in <span class="pf" data-pf="key">, so we find the
	// nearest marker under the cursor, make it contentEditable, and on commit
	// write the new text back to the matching field (or component content). The
	// resulting src change re-renders the section with the clean, marked markup.
	function startInlineEdit(e: MouseEvent, s: Section) {
		const el = (e.target as HTMLElement | null)?.closest?.('[data-pf]') as HTMLElement | null;
		if (!el) return;
		e.preventDefault();
		const field = el.getAttribute('data-pf') ?? '';
		// the text may belong to a nested component (data-pk wrapper); fall back to
		// the top-level section for preset fields, which aren't wrapped.
		const ownerEl = el.closest('[data-pk]') as HTMLElement | null;
		const ownerKey = ownerEl ? Number(ownerEl.getAttribute('data-pk')) : s.key;
		const original = el.textContent ?? '';
		editingKey = s.key;
		selectedKey = ownerKey;
		el.contentEditable = 'true';
		el.spellcheck = false;
		el.style.userSelect = 'text';
		el.focus();
		const range = document.createRange();
		range.selectNodeContents(el);
		const sel = window.getSelection();
		sel?.removeAllRanges();
		sel?.addRange(range);

		let done = false;
		const finish = (save: boolean) => {
			if (done) return;
			done = true;
			el.removeEventListener('blur', onBlur);
			el.removeEventListener('keydown', onKey);
			el.contentEditable = 'false';
			const text = (el.textContent ?? '').replace(/ /g, ' ');
			editingKey = null;
			if (save && text !== original) {
				if (field === 'content') setContent(ownerKey, text);
				else setValue(ownerKey, field, text);
			} else {
				el.textContent = original; // discard edits / no-op
			}
		};
		const onBlur = () => finish(true);
		const onKey = (ev: KeyboardEvent) => {
			if (ev.key === 'Enter' && !ev.shiftKey) {
				ev.preventDefault();
				el.blur();
			} else if (ev.key === 'Escape') {
				ev.preventDefault();
				finish(false);
			}
		};
		el.addEventListener('blur', onBlur);
		el.addEventListener('keydown', onKey);
	}
	function setStyle(key: number, patch: Partial<SectionStyle>) {
		sections = mapTree(sections, key, (s) => ({ ...s, style: { ...s.style, ...patch } }));
	}
	function clearAll() {
		if (confirm('Clear the whole page?')) {
			sections = [];
			selectedKey = null;
		}
	}

	// Recursively render a node's markup. In `editable` mode the preview gets:
	//  • data-pf spans  → double-click-to-edit text
	//  • data-drop divs → container drop zones (nesting)
	//  • data-pk wraps  → click-to-select (display:contents, so layout is intact)
	// Export mode (editable=false) emits clean, nested .pui with none of those.
	// --- per-node styling (LYK-933): a curated CSS map applied to any node's
	// wrapper in both preview and export, on top of the section band style. ---
	const CSS_PROPS = [
		'background',
		'color',
		'padding',
		'margin',
		'font-size',
		'font-weight',
		'line-height',
		'text-align',
		'border',
		'border-radius',
		'box-shadow',
		'gap',
	];
	// Theme tokens for the value/colour pickers are read from src/lib/theme.css
	// (LYK-946, ./theme-tokens) so they stay in sync with the canonical palette.
	// responsive cascade (LYK-932): the device selector edits one breakpoint;
	// narrower breakpoints override wider ones. Preview merges the active cascade
	// inline; export keeps base inline and emits the overrides as media queries.
	const BP_TABLET = 768;
	const BP_MOBILE = 480;
	const cssMapName = (): 'css' | 'cssMd' | 'cssSm' => (device === 'tablet' ? 'cssMd' : device === 'mobile' ? 'cssSm' : 'css');
	const cssMap = (n: Section, name: 'css' | 'cssMd' | 'cssSm'): Record<string, string> => (n as unknown as Record<string, Record<string, string>>)[name] ?? {};
	const mergedCss = (n: Section): Record<string, string> => ({
		...cssMap(n, 'css'),
		...(device === 'tablet' || device === 'mobile' ? cssMap(n, 'cssMd') : {}),
		...(device === 'mobile' ? cssMap(n, 'cssSm') : {}),
	});
	const styleStr = (c: Record<string, string>): string =>
		CSS_PROPS.filter((k) => c[k] != null && c[k] !== '')
			.map((k) => `${k}:${c[k]};`)
			.join('');
	function cssOf(n: Section, editable: boolean): string {
		return styleStr(editable ? mergedCss(n) : cssMap(n, 'css'));
	}
	const hasResponsive = (n: Section): boolean =>
		Object.keys(cssMap(n, 'cssMd')).length > 0 || Object.keys(cssMap(n, 'cssSm')).length > 0;
	// the value shown in the style controls for the breakpoint being edited
	const styVal = (n: Section, prop: string): string => cssMap(n, cssMapName())[prop] ?? '';
	function setCss(key: number, prop: string, value: string) {
		const mk = cssMapName();
		sections = mapTree(sections, key, (s) => {
			const m = { ...cssMap(s, mk) };
			if (value === '') delete m[prop];
			else m[prop] = value;
			return { ...s, [mk]: m };
		});
	}

	// LYK-945: read a dotted path out of the inline data ("hero.title", "items.0.name").
	const resolvePath = (obj: unknown, path: string): unknown =>
		path.split('.').reduce<unknown>((o, k) => (o == null ? undefined : (o as Record<string, unknown>)[k]), obj);
	// Flatten the data object to selectable leaf paths (strings/numbers/booleans) for the binding picker.
	function dataPaths(obj: unknown, prefix = ''): string[] {
		if (obj == null || typeof obj !== 'object') return prefix ? [prefix] : [];
		const out: string[] = [];
		for (const [k, v] of Object.entries(obj as Record<string, unknown>)) {
			const p = prefix ? `${prefix}.${k}` : k;
			if (v != null && typeof v === 'object') out.push(...dataPaths(v, p));
			else out.push(p);
		}
		return out;
	}
	derived dataPathOptions = dataPaths(siteData);
	// LYK-945: if `key` sits inside a repeater, the field names of that repeater's
	// array items (so the binding picker offers item fields, bound against `item`).
	function repeatAncestorFields(key: number): string[] | null {
		let rep: Section | null = null;
		const walk = (list: Section[], cur: Section | null): boolean => {
			for (const n of list) {
				const c = isRepeat(n) ? n : cur;
				if (n.key === key) {
					rep = c;
					return true;
				}
				if (n.children && walk(n.children, c)) return true;
			}
			return false;
		};
		walk(sections, null);
		if (!rep) return null;
		const arr = resolvePath(siteData, (rep as Section).source ?? '');
		const item = Array.isArray(arr) && arr.length ? arr[0] : null;
		return item && typeof item === 'object' ? Object.keys(item as Record<string, unknown>) : [];
	}
	// binding options for the currently-selected node: item fields when inside a
	// repeater, else the global data paths.
	derived bindOptions {
		if (selected) {
			const f = repeatAncestorFields(selected.key);
			if (f) return f;
		}
		return dataPathOptions;
	}
	// data paths whose value is an array — for the repeater "Repeat over" picker.
	derived arrayPathOptions {
		const out: string[] = [];
		const walk = (obj: unknown, prefix: string) => {
			if (obj == null || typeof obj !== 'object') return;
			for (const [k, v] of Object.entries(obj as Record<string, unknown>)) {
				const p = prefix ? `${prefix}.${k}` : k;
				if (Array.isArray(v)) out.push(p);
				else if (v && typeof v === 'object') walk(v, p);
			}
		};
		walk(siteData, '');
		return out;
	}
	function nodeBody(n: Section, editable: boolean, scope?: { item: unknown; ref: string }): string {
		// LYK-945: repeater — render the children template once per array item.
		// `scope` carries the current item (preview value resolution) + its var name
		// (export reference); nested repeaters shadow `item`.
		if (isRepeat(n)) {
			const src = n.source ?? '';
			const arrRaw = src ? resolvePath(scope ? scope.item : siteData, src) : undefined;
			const arr = Array.isArray(arrRaw) ? arrRaw : [];
			const tmpl = n.children ?? [];
			if (editable) {
				const childScope = { item: arr.length ? arr[0] : {}, ref: 'item' };
				const inner = tmpl.length
					? tmpl.map((c) => nodeBody(c, true, childScope)).join('\n')
					: '<span class="pdrop-empty">Drop a template component here</span>';
				const badge = `<div class="repeat-badge">↻ repeats × ${arr.length}${src ? ` over ${esc(src)}` : ' — set “Repeat over”'}</div>`;
				return `<div data-pk="${n.key}" class="repeat-zone"><div class="pdrop" data-drop="${n.key}">${inner}</div>${badge}</div>`;
			}
			if (!src || !tmpl.length) return `<!-- repeater: ${src ? 'empty template' : 'no source'} -->`;
			const childScope = { item: undefined, ref: 'item' };
			const inner = tmpl.map((c) => nodeBody(c, false, childScope)).join('\n');
			const base = scope ? `${scope.ref}.${src}` : `data.${src}`;
			return `{#each ${base} as item}\n${inner}\n{/each}`;
		}
		if (isInstance(n)) {
			const c = compById(n.ref);
			if (!c) {
				return editable
					? `<div data-pk="${n.key}" class="pf-missing">⚠ missing component</div>`
					: `<!-- missing component ${n.ref} -->`;
			}
			// export: reference the component module by its tag. preview: inline the
			// def (rendered non-editable — an instance is atomic on the page; you edit
			// it by opening the definition), wrapped so a click selects the instance.
			if (!editable) {
				const t = `<${identByComp[n.ref!]} />`;
				const sty = cssOf(n, false);
				const cls = hasResponsive(n) ? ` class="pn-${n.key}"` : '';
				return sty || cls ? `<div${cls} style="${sty}">${t}</div>` : t;
			}
			const inner = c.def.map((d) => nodeBody(d, false)).join('\n');
			return `<div data-pk="${n.key}" data-instance="${n.ref}" style="${cssOf(n, true) || 'display:contents'}">${inner}</div>`;
		}
		// free canvas → a relative box with absolutely-positioned children
		if (isFree(n)) {
			const kids = (n.children ?? [])
				.map((c) => {
					const pos =
						`position:absolute;left:${c.x ?? 24}px;top:${c.y ?? 24}px;` + (c.w ? `width:${c.w}px;` : '') + (c.h ? `height:${c.h}px;` : '');
					return `<div style="${pos}">\n${nodeBody(c, false, scope)}\n</div>`;
				})
				.join('\n');
			const minH = Math.max(240, ...(n.children ?? []).map((c) => (c.y ?? 0) + (c.h ?? 80)));
			return `<div class="free-canvas" style="position:relative; min-height:${minH}px;">\n${kids}\n</div>`;
		}
		if (!isComp(n)) {
			const def = defOf(n);
			// Unknown block type (e.g. from corrupt/old state): render a contained
			// placeholder instead of throwing and blanking the whole canvas.
			if (!def) return editable ? `<div class="sec-err">Unknown block: ${esc(n.type)}</div>` : `<!-- unknown block: ${n.type} -->`;
			const html = markupOf(def, n.values, editable);
			const sty = cssOf(n, editable);
			const cls = !editable && hasResponsive(n) ? ` class="pn-${n.key}"` : '';
			return sty || cls ? `<div${cls} style="${sty}">${html}</div>` : html;
		}
		// LYK-945: props bound to data. Build the open tag from the unbound props,
		// then append each bound prop as an expression — preview bakes the resolved
		// value, export references `data`/`item`.
		const pBinds = n.propBind ?? {};
		const baseProps = { ...(n.props ?? {}) };
		for (const k of Object.keys(pBinds)) if (pBinds[k]) delete baseProps[k];
		let open = componentOpen(n.comp!, baseProps);
		for (const [k, path] of Object.entries(pBinds)) {
			if (!path) continue;
			open += editable
				? ` ${k}={${JSON.stringify(resolvePath(scope ? scope.item : siteData, path) ?? null)}}`
				: ` ${k}={${scope ? scope.ref : 'data'}.${path}}`;
		}
		let tag: string;
		if (!takesContent(n.comp!)) {
			tag = `${open} />`;
		} else {
			let inner: string;
			if (n.children && n.children.length) {
				inner = n.children.map((c) => nodeBody(c, editable, scope)).join('\n');
			} else if (n.bind) {
				// LYK-945: content bound to data. Preview shows the resolved value
				// (not editable); export emits a Svelte expression. Inside a repeater
				// the binding resolves against the current `item` (scope), else `data`.
				const refBase = scope ? scope.ref : 'data';
				if (editable) {
					const v = resolvePath(scope ? scope.item : siteData, n.bind);
					inner = `<span class="pf-bound" title="Bound to ${esc(refBase)}.${esc(n.bind)}">${esc(v == null ? `{{${n.bind}}}` : String(v))}</span>`;
				} else {
					inner = `{${refBase}.${n.bind}}`;
				}
			} else if (n.content) {
				inner = editable ? `<span class="pf" data-pf="content">${n.content}</span>` : n.content;
			} else {
				inner = editable ? '<span class="pdrop-empty">Drop a component here</span>' : '';
			}
			if (editable) inner = `<div class="pdrop" data-drop="${n.key}">${inner}</div>`;
			tag = `${open}>${inner}</${identOf(n.comp!)}>`;
		}
		// The wrapper carries the node key for click-to-select; with no per-node
		// css it's display:contents (no layout box), otherwise it carries the css.
		const sty = cssOf(n, editable);
		if (editable) return `<div data-pk="${n.key}" style="${sty || 'display:contents'}">${tag}</div>`;
		const cls = hasResponsive(n) ? ` class="pn-${n.key}"` : '';
		return sty || cls ? `<div${cls} style="${sty}">${tag}</div>` : tag;
	}
	function nodeImports(n: Section, forExport = false): string[] {
		if (isInstance(n)) {
			// export references the module (import added at page/module level); preview
			// inlines the def, so it needs the def's own component imports.
			if (forExport) return [];
			const c = compById(n.ref);
			return c ? c.def.flatMap((d) => nodeImports(d, false)) : [];
		}
		if (isFree(n)) return (n.children ?? []).flatMap((c) => nodeImports(c, forExport));
		if (isRepeat(n)) return (n.children ?? []).flatMap((c) => nodeImports(c, forExport));
		if (!isComp(n)) return defOf(n)?.imports ?? [];
		const ids = [n.comp!];
		if (n.children) for (const c of n.children) ids.push(...nodeImports(c, forExport));
		return ids;
	}
	// Preview source: imports for the whole subtree (instances inlined) + nodeBody.
	const srcOf = (s: Section) => {
		const imps = [...new Set(nodeImports(s))].map(importLine).join('\n');
		return `<script lang="pts">\n${imps}\n<\/script>\n\n${nodeBody(s, true)}\n`;
	};
	const sectionImports = (s: Section): string[] => [...new Set(nodeImports(s, true))];
	// component ids instanced anywhere in a node list (page or a def), at any depth.
	function instanceRefsIn(list: Section[]): string[] {
		const out: string[] = [];
		for (const n of list) {
			if (isInstance(n) && n.ref) out.push(n.ref);
			if (n.children) out.push(...instanceRefsIn(n.children));
		}
		return out;
	}
	const sectionBody = (s: Section): string => nodeBody(s, false);
	const secStyle = (s: Section) =>
		`background:${s.style.bg}; padding:${s.style.padY}px 24px;` + (s.style.fg === 'light' ? ' color:#fff;' : '');
	const innerStyle = (s: Section) =>
		`max-width:${s.style.width ? s.style.width + 'px' : 'none'}; margin:0 auto; text-align:${s.style.align};`;

	// Live render: compile each section's content and mount it. Recompiles only
	// when the source string changes (content edits) — style edits are inline.
	function renderSection(el: HTMLElement, src: string) {
		let teardown: (() => void) | null = null;
		let last: string | null = null;
		function run(s: string) {
			if (s === last) return;
			last = s;
			teardown?.();
			teardown = null;
			el.innerHTML = '';
			try {
				const C = compileParascape(s);
				teardown = mountSvelte(C as never, el);
			} catch (e: unknown) {
				const d = document.createElement('div');
				d.className = 'sec-err';
				d.textContent = (e as { message?: string })?.message ?? String(e);
				el.appendChild(d);
			}
		}
		run(src);
		return { update: (s: string) => run(s), destroy: () => teardown?.() };
	}

	// --- combine the whole page into one downloadable .pui file ---
	// Each section is exported as a Parascape <Section> band (no raw section/div
	// wrappers); the content is built from components too (Box/Columns/Header/…).
	// Kept per-section so the export view can map a hovered block to its section.
	const segmentOf = (s: Section): string => {
		const st = s.style;
		const attrs = [
			`bg="${st.bg}"`,
			`padY={${st.padY}}`,
			st.fg === 'light' ? 'fg="light"' : '',
			`align="${st.align}"`,
			`width={${st.width}}`,
		]
			.filter(Boolean)
			.join(' ');
		const body = sectionBody(s)
			.split('\n')
			.map((l) => '\t\t' + l)
			.join('\n');
		return `\t<Section ${attrs}>\n${body}\n\t</Section>`;
	};
	derived pageSegments = sections.map((s) => ({ key: s.key, label: labelOf(s), code: segmentOf(s) }));
	// Components reachable from this page (instanced on it, plus any they reference
	// transitively) — each exported as its own reusable .pui module.
	derived pageModules {
		const want = new Set<string>();
		const visit = (ids: string[]) => {
			for (const id of ids) {
				const c = compById(id);
				if (!c || want.has(id)) continue;
				want.add(id);
				visit(instanceRefsIn(c.def));
			}
		};
		visit(instanceRefsIn(sections));
		return components
			.filter((c) => want.has(c.id))
			.map((c) => {
				const ident = identByComp[c.id];
				const meta = [...new Set(c.def.flatMap((d) => nodeImports(d, true)))].map(importLine);
				const mods = [...new Set(instanceRefsIn(c.def))]
					.filter((id) => compById(id))
					.map((id) => `import ${identByComp[id]} from './${identByComp[id]}.pui';`);
				const imps = [...meta, ...mods].filter(Boolean).join('\n');
				const body = c.def.map((d) => nodeBody(d, false)).join('\n');
				return { id: c.id, name: c.name, ident, filename: `${ident}.pui`, source: `<script lang="pts">\n${imps}\n<\/script>\n\n${body}\n` };
			});
	}
	// `section` is the band wrapper every segment uses, plus each section's own
	// component imports, plus an import for every named component instanced here.
	derived pageImports {
		const meta = [...new Set(['section', ...sections.flatMap(sectionImports)])].map(importLine);
		const mods = pageModules.map((m) => `import ${m.ident} from './${m.filename}';`);
		return [...meta, ...mods].filter(Boolean).join('\n');
	}
	// route + declared params of the active page, emitted as a header comment so
	// the exported .pui carries its routing metadata.
	derived routeComment {
		const p = activePage;
		if (!p) return '';
		const params = p.params.trim();
		return `<!-- route: ${p.route}${params ? `  params: ${params}` : ''} -->\n`;
	}
	// Per-page SEO / social tags (LYK-947) → exported/published <svelte:head>.
	// `esc` doesn't cover double quotes, so attribute values get extra escaping.
	derived metaHead {
		const m = activePage?.meta ?? {};
		const attr = (s: string) => esc(s).split('"').join('&quot;');
		// Page-name title fallback only when the page sets SOME explicit SEO, so
		// pages without metadata keep the default (head-less) export. The trailing
		// `if (!tags.length) return ''` then naturally emits nothing.
		const explicit = m.title || m.description || m.image || m.favicon || m.lang;
		const title = (m.title || (explicit ? activePage?.name : '') || '').trim();
		const tags: string[] = [];
		if (title) {
			tags.push(`<title>${esc(title)}</title>`);
			tags.push(`<meta property="og:title" content="${attr(title)}" />`);
			tags.push(`<meta name="twitter:title" content="${attr(title)}" />`);
		}
		const desc = (m.description ?? '').trim();
		if (desc) {
			tags.push(`<meta name="description" content="${attr(desc)}" />`);
			tags.push(`<meta property="og:description" content="${attr(desc)}" />`);
			tags.push(`<meta name="twitter:description" content="${attr(desc)}" />`);
		}
		const img = (m.image ?? '').trim();
		if (img) {
			tags.push(`<meta property="og:image" content="${attr(img)}" />`);
			tags.push(`<meta name="twitter:image" content="${attr(img)}" />`);
			tags.push(`<meta name="twitter:card" content="summary_large_image" />`);
		}
		const fav = (m.favicon ?? '').trim();
		if (fav) tags.push(`<link rel="icon" href="${attr(fav)}" />`);
		const lang = (m.lang ?? '').trim();
		if (lang) tags.push(`<meta property="og:locale" content="${attr(lang)}" />`);
		if (!tags.length) return '';
		tags.push(`<meta property="og:type" content="website" />`);
		return `<svelte:head>\n\t${tags.join('\n\t')}\n<\/svelte:head>\n\n`;
	}
	// LYK-945: when any node binds to data, declare `const data = …` in the
	// exported page so the `{data.path}` expressions resolve.
	derived hasBinding {
		const walk = (list: Section[]): boolean =>
			list.some(
				(n) =>
					!!n.bind ||
					(n.propBind && Object.keys(n.propBind).length > 0) ||
					(isRepeat(n) && !!n.source) ||
					(n.children ? walk(n.children) : false),
			);
		return walk(sections);
	}
	// `const data = …` for inline sources; a live `signal data` + fetch effect when
	// a CMS/API URL is configured (LYK-945) so the published page loads it at runtime.
	derived dataDecl {
		if (!hasBinding) return '';
		const url = dataUrl.trim();
		if (url)
			return `\tsignal data = {};\n\teffect { fetch(${JSON.stringify(url)}).then((r) => r.json()).then((d) => (data = d)).catch(() => {}); }\n`;
		return `\tconst data = ${JSON.stringify(siteData)};\n`;
	}
	derived exportHead = sections.length ? `${routeComment}${metaHead}<script lang="pts">\n${pageImports}\n${dataDecl}<\/script>\n\n<div class="page">` : '';
	// Media-query rules from per-node responsive overrides (LYK-932): each node
	// with cssMd/cssSm exports a `.pn-<key>` class targeted at ≤768 / ≤480.
	derived responsiveCss {
		const rules: string[] = [];
		const walk = (list: Section[]) => {
			for (const n of list) {
				const md = cssMap(n, 'cssMd');
				const sm = cssMap(n, 'cssSm');
				if (Object.keys(md).length) rules.push(`\t@media (max-width: ${BP_TABLET}px) { .pn-${n.key} { ${styleStr(md)} } }`);
				if (Object.keys(sm).length) rules.push(`\t@media (max-width: ${BP_MOBILE}px) { .pn-${n.key} { ${styleStr(sm)} } }`);
				if (n.children) walk(n.children);
			}
		};
		walk(sections);
		return rules.join('\n');
	}
	derived exportFoot = `</div>\n\n<style>\n\t.page { display: flex; flex-direction: column; }${responsiveCss ? '\n' + responsiveCss : ''}\n</style>\n`;
	derived pageSource {
		// Code Mode override is the canonical source when present.
		if (codeOverride !== null) return codeOverride;
		if (!sections.length) return '';
		const body = pageSegments.map((seg) => seg.code).join('\n');
		return `${exportHead}\n${body}\n${exportFoot}`;
	}
	// The .pui the blocks would generate, ignoring any code override (used to seed
	// the Code Mode editor from the current visual page).
	derived blockSource {
		if (!sections.length) return '<script lang="pts">\n<\/script>\n\n<div class="page"></div>\n';
		const body = pageSegments.map((seg) => seg.code).join('\n');
		return `${exportHead}\n${body}\n${exportFoot}`;
	}

	// Shiki-highlight a code string into `el` (async; re-runs on update). Tab
	// indentation in the exported source renders at 2 spaces via CSS tab-size.
	function hl(el: HTMLElement, code: string) {
		let last: string | null = null;
		function run(c: string) {
			if (c === last) return;
			last = c;
			highlight(c, 'pui')
				.then((html) => {
					if (last === c) el.innerHTML = html;
				})
				.catch(() => {
					el.textContent = c;
				});
		}
		run(code);
		return { update: run };
	}
	function download() {
		let text = codeMode ? codeDraft : pageSource;
		let name = 'Page.pui';
		// With named components, one .pui can't hold every module — bundle the page
		// and each component module into one text file with file separators.
		if (!codeMode && pageModules.length) {
			const mods = pageModules.map((m) => `// ===== ${m.filename} =====\n${m.source}`).join('\n');
			text = `// ===== Page.pui =====\n${text}\n\n${mods}`;
			name = 'parascape-export.txt';
		}
		const blob = new Blob([text], { type: 'text/plain' });
		const url = URL.createObjectURL(blob);
		const a = document.createElement('a');
		a.href = url;
		a.download = name;
		a.click();
		URL.revokeObjectURL(url);
	}

	// --- Code Mode: edit the raw .pui; the code is canonical (an override the
	// canvas renders and exports). Edits validate-then-apply (debounced) so a
	// transient parse error keeps the last good render. Revert drops the override
	// and returns to editing the visual blocks. ---
	function toggleCode() {
		codeMode = !codeMode;
		if (codeMode) {
			codeDraft = codeOverride ?? blockSource;
			codeErr = null;
			showExport = false;
			selectedKey = null;
		}
	}
	let codeTimer: ReturnType<typeof setTimeout> | undefined;
	function applyCode() {
		try {
			compileParascape(codeDraft); // validate
			codeErr = null;
			codeErrLine = null;
			codeOverride = codeDraft;
		} catch (e: unknown) {
			const err = e as { message?: string; start?: { line?: number }; line?: number };
			codeErr = err?.message ?? String(e);
			// surface the offending line: the compiler object first, else parse the
			// message — prefer the `(line:col)` form, then a "line N" mention.
			const paren = (codeErr ?? '').match(/\((\d+):\d+\)/);
			const lineKw = (codeErr ?? '').match(/line\s*(\d+)/i);
			codeErrLine = err?.start?.line ?? err?.line ?? (paren ? Number(paren[1]) : lineKw ? Number(lineKw[1]) : null);
		}
	}
	// --- Code Mode autocomplete (LYK-939) ---
	// component tags after `<`, or prop names inside an open tag — sourced from the
	// component list + manifests (editableProps).
	type Completion = { label: string; insert: string; detail: string };
	derived codeCompletions {
		if (!codeMode) return [] as Completion[];
		const before = codeDraft.slice(0, codeCaret);
		const tag = before.match(/<([A-Za-z][A-Za-z0-9]*)$/);
		if (tag) {
			const partial = tag[1].toLowerCase();
			return allComponents
				.filter((c) => c.name.toLowerCase().startsWith(partial))
				.slice(0, 8)
				.map((c) => ({ label: c.name, insert: c.name, detail: 'component' }));
		}
		const open = before.match(/<([A-Z][A-Za-z0-9]*)(\s[^<>]*)$/);
		if (open) {
			const id = allComponents.find((c) => c.name === open[1])?.id;
			if (id) {
				const word = ((open[2].match(/([a-zA-Z]*)$/) ?? ['', ''])[1] ?? '').toLowerCase();
				return editableProps(id)
					.filter((p) => p.name.toLowerCase().startsWith(word))
					.slice(0, 8)
					.map((p) => ({ label: p.name, insert: p.name + '=""', detail: p.type.trim().slice(0, 22) }));
			}
		}
		return [] as Completion[];
	}
	function applyCompletion(c: Completion) {
		const before = codeDraft.slice(0, codeCaret);
		const tag = before.match(/<([A-Za-z][A-Za-z0-9]*)$/);
		const partial = tag ? tag[1] : (before.match(/([a-zA-Z]*)$/) ?? ['', ''])[1];
		const start = codeCaret - partial.length;
		codeDraft = codeDraft.slice(0, start) + c.insert + codeDraft.slice(codeCaret);
		const caret = start + c.insert.length;
		codeCaret = caret;
		queueMicrotask(() => {
			const ta = document.querySelector('.code-ta') as HTMLTextAreaElement | null;
			if (ta) {
				ta.focus();
				ta.selectionStart = ta.selectionEnd = caret;
			}
		});
		onCodeInput();
	}
	function onCodeInput() {
		clearTimeout(codeTimer);
		codeTimer = setTimeout(applyCode, 300);
	}
	function codeTab(e: KeyboardEvent) {
		if (e.key !== 'Tab') return;
		e.preventDefault();
		const ta = e.currentTarget as HTMLTextAreaElement;
		const s = ta.selectionStart;
		codeDraft = codeDraft.slice(0, s) + '\t' + codeDraft.slice(ta.selectionEnd);
		queueMicrotask(() => (ta.selectionStart = ta.selectionEnd = s + 1));
	}
	// keep the highlighted <pre> and the gutter aligned with the textarea scroll
	function codeSync(e: Event) {
		const ta = e.currentTarget as HTMLTextAreaElement;
		const pre = ta.previousElementSibling as HTMLElement | null;
		if (pre) {
			pre.scrollTop = ta.scrollTop;
			pre.scrollLeft = ta.scrollLeft;
		}
		codeScrollY = ta.scrollTop;
	}
	function revertToVisual() {
		codeOverride = null;
		codeErr = null;
		codeMode = false;
	}

	// --- AI generation (LYK-936) ---
	// POST the prompt to the ParaBun llm-server; the returned .pui becomes the
	// page's canonical source (Code Mode) — the same render/edit/export path the
	// Builder fed AI output into, now inside the unified Designer.
	async function generateAI() {
		const prompt = aiPrompt.trim();
		if (!prompt || aiBusy) return;
		aiBusy = true;
		aiError = null;
		try {
			const res = await fetch(AI_ENDPOINT.replace(/\/$/, '') + '/generate', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ prompt }),
			});
			if (!res.ok) throw new Error('server returned ' + res.status);
			const data = (await res.json()) as { source?: string; error?: string };
			if (data.error) throw new Error(data.error);
			if (!data.source?.trim()) throw new Error('empty response');
			compileParascape(data.source); // validate before adopting
			if (editingComponentId) exitComponentEdit();
			codeDraft = data.source;
			codeOverride = data.source;
			codeMode = true;
			showExport = false;
			showA11y = false;
			selectedKey = null;
			aiPrompt = '';
		} catch (e: unknown) {
			aiError = ((e as { message?: string })?.message ?? String(e)) + ' — is the ParaBun llm-server running? (parabun builder/llm-server.ts)';
		} finally {
			aiBusy = false;
		}
	}

	// --- media library (LYK-935) ---
	async function loadAssets() {
		try {
			assets = await account.listAssets();
		} catch {
			assets = [];
		}
	}
	async function onAssetFiles(files: FileList | null) {
		if (!files?.length) return;
		assetErr = null;
		try {
			for (const f of Array.from(files)) if (f.type.startsWith('image/')) await account.uploadAsset(f);
			await loadAssets();
		} catch (e: unknown) {
			assetErr = (e as { message?: string })?.message ?? 'Upload failed';
		}
	}
	async function removeAsset(id: number) {
		try {
			await account.deleteAsset(id);
			await loadAssets();
		} catch {}
	}
	// Insert an Image section pointing at the uploaded asset's stable URL (alt
	// pre-filled from the file name for a11y; editable in the inspector).
	function insertImage(a: AssetMeta) {
		insertSection(
			{ key: nextKey++, type: 'image', values: { src: account.assetUrl(a.id), alt: a.name }, style: { ...SECTION_BY_ID['image'].style } },
			sections.length,
		);
	}

	// --- publish / dev preview (LYK-934) ---
	async function publishPage() {
		if (publishBusy) return;
		publishBusy = true;
		publishUrl = null;
		try {
			const slug =
				(activePage?.name || 'page')
					.toLowerCase()
					.replace(/[^a-z0-9-]+/g, '-')
					.replace(/^-+|-+$/g, '') || 'page';
			// Publish the current page's exported .pui; image assets resolve via the
			// dev server's /api/assets URLs, so the preview is self-contained.
			const r = await account.publish(slug, { name: activePage?.name ?? 'Page', source: pageSource });
			publishUrl = `/preview/?slug=${encodeURIComponent(r.slug)}`;
		} catch (e: unknown) {
			alert((e as { message?: string })?.message ?? 'Publish failed — needs the account server (sign in or guest mode).');
		} finally {
			publishBusy = false;
		}
	}

	// --- Accessibility check (LYK-931) ---
	// Runs real axe-core over the live preview (a real browser, so layout-dependent
	// rules like colour-contrast are accurate) and lists violations worst-first.
	const IMPACT_RANK: Record<string, number> = { critical: 0, serious: 1, moderate: 2, minor: 3 };
	async function scanA11y() {
		if (typeof document === 'undefined') return;
		a11yScanning = true;
		a11yResults = null;
		await new Promise((r) => requestAnimationFrame(() => r(null))); // let the preview settle
		const el = document.querySelector('.canvas .frame') as HTMLElement | null;
		if (!el) {
			a11yScanning = false;
			a11yResults = [];
			return;
		}
		try {
			const res = await axe.run(el, { resultTypes: ['violations'] });
			a11yResults = res.violations
				.map((v) => ({
					impact: v.impact ?? 'minor',
					id: v.id,
					help: v.help,
					helpUrl: v.helpUrl,
					count: v.nodes.length,
					target: String(v.nodes[0]?.target?.[0] ?? ''),
				}))
				.sort((a, b) => (IMPACT_RANK[a.impact] ?? 9) - (IMPACT_RANK[b.impact] ?? 9));
		} catch {
			a11yResults = [];
		} finally {
			a11yScanning = false;
		}
	}
	function toggleA11y() {
		showA11y = !showA11y;
		if (showA11y) {
			showExport = false;
			scanA11y();
		}
	}

	// --- Account + server persistence (LYK-930) ---
	const maxKeyOf = (list: Section[]): number => {
		let m = 0;
		for (const n of list) {
			if (n.key > m) m = n.key;
			if (n.children) m = Math.max(m, maxKeyOf(n.children));
		}
		return m;
	};
	// Replace the whole project (all pages) — used when loading from the server.
	function applyProject(raw: unknown) {
		const proj = toProject(raw);
		pages = proj.pages;
		activePageId = proj.activePageId;
		nextKey = Math.max(nextKey, proj.nextKey);
		nextPageId = Math.max(nextPageId, ...proj.pages.map((p) => p.id)) + 1;
		components = proj.components;
		nextCompId = Math.max(nextCompId, proj.nextCompId);
		siteData = proj.data ?? {};
		dataText = JSON.stringify(siteData, null, 2);
		dataUrl = proj.dataUrl ?? '';
		editingComponentId = null;
		pageSectionsStash = null;
		const active = proj.pages.find((p) => p.id === proj.activePageId) ?? proj.pages[0];
		loadPageDoc(active.doc);
	}
	async function loadFromServer() {
		const ps = await account.listProjects();
		if (ps.length) {
			const p = await account.getProject(ps[0].id);
			projectId = p.id;
			applyProject(p.doc);
		} else {
			projectId = await account.createProject('My site', currentProject());
		}
		saveState = 'saved';
		loadAssets();
		loadSnapshots();
		startCollab();
	}

	// --- real-time collaboration (LYK-944) ---
	// Mirror the open project into a CRDT shared with the project's other editors.
	// Guest mode is single-user, so it's skipped. A peer's change is folded in while
	// preserving MY viewport: I keep my own active page + selection, take peers' edits
	// to every OTHER page, and only reload my current page if a peer actually changed
	// it (last-writer-wins on a shared page).
	function startCollab() {
		if (collab || guest || !acct || projectId === null) return;
		const token = account.getToken();
		if (!token) return;
		const c = createCollab({ projectId, token, selfName: acct.username, selfId: String(acct.id), getLocal: () => currentProject() });
		c.on('status', (online) => (collabLive = online));
		c.on('presence', (list) => (collabPeers = list));
		c.on('remote', (raw) => {
			applyingRemote = true;
			try {
				const np = toProject(raw);
				const keepActive = activePageId;
				const keepSel = selectedKey;
				const myActiveDoc = activeDoc();
				nextKey = Math.max(nextKey, np.nextKey);
				nextCompId = Math.max(nextCompId, np.nextCompId);
				components = np.components;
				siteData = np.data ?? {};
				dataText = JSON.stringify(siteData, null, 2);
				dataUrl = np.dataUrl ?? '';
				pages = np.pages.map((p) => (p.id === keepActive ? { ...p, doc: myActiveDoc } : p));
				if (np.pages.length) nextPageId = Math.max(nextPageId, ...np.pages.map((p) => p.id)) + 1;
				const remoteActive = np.pages.find((p) => p.id === keepActive);
				if (!pages.some((p) => p.id === keepActive)) {
					const first = pages[0];
					if (first) {
						activePageId = first.id;
						loadPageDoc(first.doc);
					}
				} else if (remoteActive && stableStringify(remoteActive.doc.sections) !== stableStringify(myActiveDoc.sections)) {
					loadPageDoc(remoteActive.doc);
					selectedKey = keepSel !== null && findNode(sections, keepSel) ? keepSel : null;
				}
			} finally {
				applyingRemote = false;
			}
		});
		collab = c;
		c.connect(); // the room's state seeds us (or we seed it if it's empty)
	}
	// canvas-relative cursor (0..1 fractions, so it maps across zoom/viewport).
	function onCanvasPointerMove(e: PointerEvent) {
		if (!collab) return;
		const el = (e.currentTarget as HTMLElement).getBoundingClientRect();
		if (!el.width || !el.height) return;
		collab.setCursor((e.clientX - el.left) / el.width, (e.clientY - el.top) / el.height, activePageId);
	}
	// peers editing the page I'm viewing, with a resolved cursor position
	derived cursorPeers = collabPeers.filter((p) => p.cursor && p.page === activePageId);

	// --- version history / snapshots (LYK-943) ---
	async function loadSnapshots() {
		try {
			snapshots = await account.listSnapshots();
		} catch {
			snapshots = [];
		}
	}
	async function saveSnapshot() {
		if (historyBusy) return;
		const label = (prompt('Name this version', `Snapshot ${new Date().toLocaleString()}`) ?? '').trim();
		if (!label) return;
		historyBusy = true;
		try {
			await account.createSnapshot(label, currentProject());
			await loadSnapshots();
		} catch (e: unknown) {
			alert((e as { message?: string })?.message ?? 'Could not save snapshot.');
		} finally {
			historyBusy = false;
		}
	}
	async function restoreSnapshot(id: number) {
		if (historyBusy) return;
		if (!confirm('Restore this version? Your current page replaces with the snapshot (autosaved).')) return;
		historyBusy = true;
		try {
			const snap = await account.getSnapshot(id);
			applyProject(snap.doc);
		} catch (e: unknown) {
			alert((e as { message?: string })?.message ?? 'Could not restore snapshot.');
		} finally {
			historyBusy = false;
		}
	}
	async function removeSnapshot(id: number) {
		if (historyBusy) return;
		historyBusy = true;
		try {
			await account.deleteSnapshot(id);
			snapshots = snapshots.filter((s) => s.id !== id);
		} catch {
		} finally {
			historyBusy = false;
		}
	}
	const relTime = (ms: number): string => {
		const s = Math.floor((Date.now() - ms) / 1000);
		if (s < 60) return 'just now';
		const m = Math.floor(s / 60);
		if (m < 60) return `${m}m ago`;
		const h = Math.floor(m / 60);
		if (h < 24) return `${h}h ago`;
		return new Date(ms).toLocaleDateString();
	};
	// On mount, probe the session: in guest mode the server returns the guest user
	// with no token (→ silent persistence, account UI hidden); with a real token it
	// returns that user; otherwise 401 → signed out (web build shows Sign in).
	effect {
		if (typeof document === 'undefined') return;
		(async () => {
			// Detect guest mode via the always-200 health probe first, so the web
			// build doesn't fire a spurious 401 on /me when signed out.
			let serverGuest = false;
			try {
				serverGuest = (await account.health()).guest;
			} catch {
				return; // no backend reachable → stay local-only
			}
			if (!serverGuest && !account.getToken()) return; // web, signed out → don't probe /me
			try {
				const s = await account.me();
				acct = s.user;
				guest = s.guest;
				await loadFromServer();
			} catch {
				acct = null; // not signed in (no/expired token, non-guest server)
			}
		})();
	}
	// debounced server autosave (signed in only); localStorage autosave above
	// continues regardless as the offline cache.
	let serverSaveTimer: ReturnType<typeof setTimeout> | undefined;
	effect {
		const _s = sections,
			_c = codeOverride,
			_p = pages,
			_a = activePageId,
			_d = siteData,
			_du = dataUrl; // track edits + page changes
		untrack(() => {
			collab?.push(currentProject()); // mirror local edits to peers (idempotent if unchanged)
			if (!acct || projectId === null) return;
			const pid = projectId;
			saveState = 'saving';
			clearTimeout(serverSaveTimer);
			serverSaveTimer = setTimeout(async () => {
				try {
					await account.saveProject(pid, currentProject());
					saveState = 'saved';
				} catch {
					saveState = 'error';
				}
			}, 600);
		});
	}
	function openAuth(mode: 'login' | 'register') {
		authMode = mode;
		authErr = '';
		showAuth = true;
	}
	async function submitAuth() {
		if (authBusy) return;
		authBusy = true;
		authErr = '';
		try {
			acct =
				authMode === 'register'
					? await account.register(authUser.trim(), authPass)
					: await account.login(authUser.trim(), authPass);
			showAuth = false;
			authPass = '';
			await loadFromServer();
		} catch (e: unknown) {
			authErr = (e as { message?: string })?.message ?? 'Sign-in failed';
		} finally {
			authBusy = false;
		}
	}
	async function doLogout() {
		await account.logout();
		acct = null;
		projectId = null;
		saveState = 'offline';
	}
	derived saveLabel = saveState === 'saving' ? 'Saving…' : saveState === 'saved' ? 'Saved' : saveState === 'error' ? 'Save failed' : '';
</script>

<svelte:window onkeydown={onGlobalKey} />

<!-- Layers outline row (recursive over the node tree) -->
{#snippet layerRow(node: Section, depth: number)}
	<div class="layer-row" class:sel={node.key === selectedKey} style="padding-left: {8 + depth * 14}px">
		<button class="layer-pick" onclick={() => { selectedKey = node.key; showExport = false; }}>
			<span class="layer-icon" aria-hidden="true">{isFree(node) ? '▦' : isInstance(node) ? '◈' : isComp(node) ? '◇' : '▭'}</span>
			<span class="layer-label">{labelOf(node)}</span>
		</button>
		<button class="layer-del" title="Delete" aria-label="Delete {labelOf(node)}" onclick={(e) => { e.stopPropagation(); removeSection(node.key); }}>✕</button>
	</div>
	{#if node.children}
		{#each node.children as c (c.key)}{@render layerRow(c, depth + 1)}{/each}
	{/if}
{/snippet}

<!-- Per-node "Element style" controls (LYK-933) — shown for every node type -->
{#snippet colorSwatches(node, prop)}
	<div class="swatches" role="group" aria-label="Theme colour tokens">
		{#each COLOR_TOKENS as name (name)}
			<button
				type="button"
				class="swatch"
				class:on={styVal(node, prop) === `var(${name})`}
				style="background: var({name})"
				title={name}
				aria-label="Set {prop} to {name}"
				onclick={() => setCss(node.key, prop, `var(${name})`)}
			></button>
		{/each}
	</div>
{/snippet}

{#snippet styleGroup(node)}
	<details class="style-group">
		<summary>Element style{device !== 'desktop' ? ` · ${device} only` : ''}</summary>
		{#if device !== 'desktop'}
			<p class="bp-note">Editing the <strong>{device}</strong> breakpoint — overrides inherit from desktop.</p>
		{/if}
		<label class="field"><span>Text colour</span>
			<input value={styVal(node, 'color')} placeholder="color or var(--…)" oninput={(e) => setCss(node.key, 'color', (e.target as HTMLInputElement).value)} />
		</label>
		{@render colorSwatches(node, 'color')}
		<label class="field"><span>Background</span>
			<input value={styVal(node, 'background')} placeholder="color or var(--…)" oninput={(e) => setCss(node.key, 'background', (e.target as HTMLInputElement).value)} />
		</label>
		{@render colorSwatches(node, 'background')}
		<label class="field"><span>Padding</span>
			<span class="bg-row">
				<input value={styVal(node, 'padding')} placeholder="e.g. 16px or 8px 16px" oninput={(e) => setCss(node.key, 'padding', (e.target as HTMLInputElement).value)} />
				<select onchange={(e) => { setCss(node.key, 'padding', (e.target as HTMLSelectElement).value); (e.target as HTMLSelectElement).selectedIndex = 0; }}>
					<option value="">scale…</option>
					{#each SPACE_SCALE as t (t)}<option value={t}>{t}</option>{/each}
				</select>
			</span>
		</label>
		<label class="field"><span>Margin</span>
			<span class="bg-row">
				<input value={styVal(node, 'margin')} placeholder="e.g. 0 0 16px" oninput={(e) => setCss(node.key, 'margin', (e.target as HTMLInputElement).value)} />
				<select onchange={(e) => { setCss(node.key, 'margin', (e.target as HTMLSelectElement).value); (e.target as HTMLSelectElement).selectedIndex = 0; }}>
					<option value="">scale…</option>
					{#each SPACE_SCALE as t (t)}<option value={t}>{t}</option>{/each}
				</select>
			</span>
		</label>
		<label class="field"><span>Font size</span>
			<input value={styVal(node, 'font-size')} placeholder="e.g. 18px" oninput={(e) => setCss(node.key, 'font-size', (e.target as HTMLInputElement).value)} />
		</label>
		<label class="field"><span>Font weight</span>
			<select value={styVal(node, 'font-weight')} onchange={(e) => setCss(node.key, 'font-weight', (e.target as HTMLSelectElement).value)}>
				<option value="">(default)</option>
				<option value="400">Regular</option>
				<option value="500">Medium</option>
				<option value="600">Semibold</option>
				<option value="700">Bold</option>
			</select>
		</label>
		<label class="field"><span>Text align</span>
			<select value={styVal(node, 'text-align')} onchange={(e) => setCss(node.key, 'text-align', (e.target as HTMLSelectElement).value)}>
				<option value="">(default)</option>
				<option value="left">Left</option>
				<option value="center">Center</option>
				<option value="right">Right</option>
			</select>
		</label>
		<label class="field"><span>Border</span>
			<input value={styVal(node, 'border')} placeholder="e.g. 1px solid var(--border)" oninput={(e) => setCss(node.key, 'border', (e.target as HTMLInputElement).value)} />
		</label>
		<label class="field"><span>Radius</span>
			<span class="bg-row">
				<input value={styVal(node, 'border-radius')} placeholder="e.g. 8px" oninput={(e) => setCss(node.key, 'border-radius', (e.target as HTMLInputElement).value)} />
				<select onchange={(e) => { setCss(node.key, 'border-radius', (e.target as HTMLSelectElement).value); (e.target as HTMLSelectElement).selectedIndex = 0; }}>
					<option value="">token…</option>
					{#each RADIUS_TOKENS as name (name)}<option value={`var(${name})`}>{name}</option>{/each}
				</select>
			</span>
		</label>
		<label class="field"><span>Shadow</span>
			<span class="bg-row">
				<input value={styVal(node, 'box-shadow')} placeholder="e.g. 0 2px 8px rgba(0,0,0,.12)" oninput={(e) => setCss(node.key, 'box-shadow', (e.target as HTMLInputElement).value)} />
				<select onchange={(e) => { setCss(node.key, 'box-shadow', (e.target as HTMLSelectElement).value); (e.target as HTMLSelectElement).selectedIndex = 0; }}>
					<option value="">token…</option>
					{#each SHADOW_TOKENS as name (name)}<option value={`var(${name})`}>{name}</option>{/each}
				</select>
			</span>
		</label>
	</details>
{/snippet}

<div class="designer">
	<SiteNav active="designer" />
	<header class="dtoolbar">
		<strong>Site Designer</strong>
		<span class="muted">{sections.length} section{sections.length === 1 ? '' : 's'}</span>
		<div class="histbtns">
			<button title="Undo (⌘Z)" aria-label="Undo" disabled={!canUndo} onclick={undo}>↶</button>
			<button title="Redo (⌘⇧Z)" aria-label="Redo" disabled={!canRedo} onclick={redo}>↷</button>
		</div>
		<span class="spacer"></span>
		<div class="devices">
			<button class:on={device === 'desktop'} onclick={() => (device = 'desktop')}>Desktop</button>
			<button class:on={device === 'tablet'} onclick={() => (device = 'tablet')}>Tablet</button>
			<button class:on={device === 'mobile'} onclick={() => (device = 'mobile')}>Mobile</button>
		</div>
		<div class="zoomctl" title="Canvas zoom (⌘ +/−/0)">
			<button aria-label="Zoom out" onclick={() => setZoom(zoom - 0.1)}>−</button>
			<button class="zoom-pct" aria-label="Reset zoom to 100%" onclick={() => (zoom = 1)}>{Math.round(zoom * 100)}%</button>
			<button aria-label="Zoom in" onclick={() => setZoom(zoom + 0.1)}>+</button>
		</div>
		{#if !codeMode}<button onclick={toggleA11y} class:on={showA11y}>A11y</button>{/if}
		<button onclick={toggleCode} class:on={codeMode}>Code</button>
		{#if !codeOverride}<button onclick={() => { showExport = !showExport; selectedKey = null; }} class:on={showExport}>Export</button>{/if}
		{#if acct || guest}<button onclick={publishPage} disabled={publishBusy} title="Publish this page to the dev preview server">{publishBusy ? 'Publishing…' : 'Publish'}</button>{/if}
		{#if publishUrl}<a class="pub-link" href={publishUrl} target="_blank" rel="noreferrer">Preview ↗</a>{/if}
		<button onclick={clearAll}>Clear</button>
		{#if collabLive}
			<span class="collab" title="Live collaboration — others editing this project appear here">
				<span class="collab-dot"></span>
				{#each collabPeers as p (p.id)}
					<span class="collab-peer" style="background:{p.color}" title="{p.name} is editing">{p.name.slice(0, 1).toUpperCase()}</span>
				{/each}
				<span class="collab-count">{collabPeers.length ? `${collabPeers.length + 1} editing` : 'Live'}</span>
			</span>
		{/if}
		<span class="acct">
			{#if guest}
				<!-- desktop / single-user build: account UI hidden, saves silently -->
				{#if saveLabel}<span class="acct-save state-{saveState}">{saveLabel}</span>{/if}
			{:else if acct}
				<span class="acct-name" title="Signed in — your page is saved to your account">{acct.username}</span>
				{#if saveLabel}<span class="acct-save state-{saveState}">{saveLabel}</span>{/if}
				<button onclick={doLogout}>Sign out</button>
			{:else}
				<button onclick={() => openAuth('login')}>Sign in</button>
			{/if}
		</span>
	</header>

	{#if editingComponentId}
		<div class="comp-edit-banner">
			<span>Editing component <strong>{editingComponent?.name ?? ''}</strong> — changes update every instance.</span>
			<button class="mini" onclick={exitComponentEdit}>Done</button>
		</div>
	{/if}

	{#if showAuth && !guest}
		<div class="auth-backdrop" role="presentation" onclick={() => (showAuth = false)}>
			<form
				class="auth-modal"
				role="dialog"
				aria-modal="true"
				aria-label={authMode === 'register' ? 'Create account' : 'Sign in'}
				onclick={(e) => e.stopPropagation()}
				onsubmit={(e) => { e.preventDefault(); submitAuth(); }}
			>
				<h2>{authMode === 'register' ? 'Create your account' : 'Sign in'}</h2>
				<p class="muted">Your pages are saved to a local account (stored in SQLite on this machine).</p>
				<label class="field"><span>Username</span>
					<input bind:value={authUser} autocomplete="username" autofocus />
				</label>
				<label class="field"><span>Password</span>
					<input type="password" bind:value={authPass} autocomplete={authMode === 'register' ? 'new-password' : 'current-password'} />
				</label>
				{#if authErr}<p class="auth-err">{authErr}</p>{/if}
				<button class="primary" type="submit" disabled={authBusy}>
					{authBusy ? 'Working…' : authMode === 'register' ? 'Create account' : 'Sign in'}
				</button>
				<p class="auth-switch">
					{#if authMode === 'register'}
						Have an account? <button type="button" class="linkish" onclick={() => { authMode = 'login'; authErr = ''; }}>Sign in</button>
					{:else}
						New here? <button type="button" class="linkish" onclick={() => { authMode = 'register'; authErr = ''; }}>Create an account</button>
					{/if}
				</p>
			</form>
		</div>
	{/if}

	{#if showPalette}
		<div class="cmdk-backdrop" role="presentation" onclick={() => (showPalette = false)}>
			<div class="cmdk" role="dialog" aria-modal="true" aria-label="Command palette" onclick={(e) => e.stopPropagation()}>
				<input
					class="cmdk-input"
					placeholder="Search actions, sections, components, templates…"
					autofocus
					value={paletteQuery}
					oninput={(e) => { paletteQuery = (e.target as HTMLInputElement).value; paletteIndex = 0; }}
					onkeydown={paletteKey}
				/>
				<div class="cmdk-list">
					{#if !paletteItems.length}
						<div class="cmdk-empty">No matches</div>
					{:else}
						{#each paletteItems as it, i (it.key)}
							<button class="cmdk-item" class:on={i === paletteIndex} onmousemove={() => (paletteIndex = i)} onclick={() => runPalette(it)}>
								<span class="cmdk-label">{it.label}</span>
								<span class="cmdk-grp">{it.group}</span>
							</button>
						{/each}
					{/if}
				</div>
				<div class="cmdk-foot">↑↓ navigate · ↵ run · esc close — also: ⌘Z undo · ⌘D duplicate · Del remove · double-click to edit text</div>
			</div>
		</div>
	{/if}

	{#if recoverRaw}
		<div class="auth-backdrop" role="presentation">
			<div class="auth-modal" role="dialog" aria-modal="true" aria-label="Recover project">
				<h2>Couldn't load your saved project</h2>
				<p class="muted">The saved data looks corrupted, so we started you on a fresh page. Download a backup of the raw data first if you want to recover it by hand.</p>
				<button class="primary" onclick={downloadRecover}>Download backup</button>
				<p class="auth-switch"><button type="button" class="linkish" onclick={dismissRecover}>Start fresh</button></p>
			</div>
		</div>
	{/if}

	<div class="cols" class:exporting={showExport} class:coding={codeMode}>
		{#if !codeMode}
		<aside class="add-panel">
			{#if !editingComponentId}
			<div class="ai-box">
				<div class="ai-head">✨ Generate with AI</div>
				<textarea
					class="ai-prompt"
					placeholder="Describe a page or component to generate…"
					value={aiPrompt}
					oninput={(e) => (aiPrompt = (e.target as HTMLTextAreaElement).value)}
					onkeydown={(e) => { if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') generateAI(); }}
				></textarea>
				<button class="primary ai-go" disabled={aiBusy || !aiPrompt.trim()} onclick={generateAI}>{aiBusy ? 'Generating…' : 'Generate'}</button>
				{#if aiError}<p class="ai-err">{aiError}</p>{/if}
			</div>
			<div class="pages">
				<div class="pages-head"><span>Pages</span><button class="mini" onclick={addPage}>+ Page</button></div>
				{#each pages as p (p.id)}
					<div class="page-row" class:active={p.id === activePageId}>
						<button class="page-pick" onclick={() => switchPage(p.id)} title={p.route}>
							<span class="page-name">{p.name}</span>
							<span class="page-route">{p.route}</span>
						</button>
						{#if pages.length > 1}
							<button class="page-del" title="Delete page" aria-label="Delete page {p.name}" onclick={() => deletePage(p.id)}>✕</button>
						{/if}
					</div>
				{/each}
				{#if activePage}
					<div class="page-settings">
						<label class="field"><span>Name</span>
							<input value={activePage.name} oninput={(e) => renamePage(activePage.id, (e.target as HTMLInputElement).value)} />
						</label>
						<label class="field"><span>Route</span>
							<input value={activePage.route} oninput={(e) => setRoute(activePage.id, (e.target as HTMLInputElement).value)} placeholder="/blog/[slug]" />
						</label>
						<label class="field"><span>Query params</span>
							<input value={activePage.params} oninput={(e) => setParams(activePage.id, (e.target as HTMLInputElement).value)} placeholder="id, tab" />
						</label>
						<div class="seo-head">SEO &amp; social</div>
						<label class="field"><span>Title</span>
							<input value={activePage.meta?.title ?? ""} oninput={(e) => setMeta(activePage.id, { title: (e.target as HTMLInputElement).value })} placeholder={activePage.name} />
						</label>
						<label class="field"><span>Description</span>
							<input value={activePage.meta?.description ?? ""} oninput={(e) => setMeta(activePage.id, { description: (e.target as HTMLInputElement).value })} placeholder="Shown in search & social cards" />
						</label>
						<label class="field"><span>Social image</span>
							<input value={activePage.meta?.image ?? ""} oninput={(e) => setMeta(activePage.id, { image: (e.target as HTMLInputElement).value })} placeholder="/api/assets/… or https://…" />
						</label>
						<label class="field"><span>Favicon</span>
							<input value={activePage.meta?.favicon ?? ""} oninput={(e) => setMeta(activePage.id, { favicon: (e.target as HTMLInputElement).value })} placeholder="/favicon.ico" />
						</label>
						<label class="field"><span>Language</span>
							<input value={activePage.meta?.lang ?? ""} oninput={(e) => setMeta(activePage.id, { lang: (e.target as HTMLInputElement).value })} placeholder="en" />
						</label>
					</div>
				{/if}
				{#if acct}
					<div class="history">
						<div class="hist-head"><span>Version history</span><button class="mini" disabled={historyBusy} onclick={saveSnapshot}>+ Save</button></div>
						{#if snapshots.length}
							{#each snapshots as s (s.id)}
								<div class="hist-row">
									<div class="hist-meta">
										<span class="hist-label" title={s.label}>{s.label}</span>
										<span class="hist-time">{relTime(s.created_at)}</span>
									</div>
									<button class="hist-act" disabled={historyBusy} onclick={() => restoreSnapshot(s.id)}>Restore</button>
									<button class="hist-del" aria-label="Delete snapshot {s.label}" disabled={historyBusy} onclick={() => removeSnapshot(s.id)}>✕</button>
								</div>
							{/each}
						{:else}
							<p class="hist-empty">No saved versions yet — use + Save to capture a restore point.</p>
						{/if}
					</div>
				{/if}
				<details class="datasrc">
					<summary>Data sources</summary>
					<p class="ds-note">Define variables/collections as JSON, then bind a node’s content to a path from the inspector.</p>
						<div class="ds-url">
							<input placeholder="CMS / API URL (optional)" value={dataUrl} oninput={(e) => (dataUrl = (e.target as HTMLInputElement).value)} />
							<button class="mini" disabled={!dataUrl.trim() || dataLoading} onclick={loadDataUrl}>{dataLoading ? "…" : "Load"}</button>
						</div>
						{#if dataUrl.trim()}<p class="ds-note">Live: the published page fetches this URL at runtime; “Load” previews it here.</p>{/if}
					<textarea class="ds-json" spellcheck="false" value={dataText} oninput={(e) => setDataText((e.target as HTMLTextAreaElement).value)}></textarea>
					{#if dataError}<p class="ds-err">{dataError}</p>{/if}
				</details>
			</div>
			{/if}

			{#if components.length}
				<div class="mycomp">
					<div class="mycomp-head">My components</div>
					{#each components as c (c.id)}
						<div class="mycomp-row" class:active={c.id === editingComponentId}>
							<button
								class="mycomp-chip"
								draggable={instanceAllowed(c.id) ? 'true' : 'false'}
								disabled={!instanceAllowed(c.id)}
								ondragstart={(e) => onPaletteDragStart(e, 'instance', c.id)}
								ondragend={onDragEnd}
								onclick={() => addInstance(c.id)}
								title={instanceAllowed(c.id) ? 'Click to append an instance, or drag onto the canvas' : "Can't place a component inside itself"}
							>◈ {c.name}</button>
							<button class="mycomp-edit" title="Edit component internals" onclick={() => enterComponentEdit(c.id)}>Edit</button>
							<button class="mycomp-del" title="Delete component" aria-label="Delete component {c.name}" onclick={() => deleteComponent(c.id)}>✕</button>
						</div>
					{/each}
				</div>
			{/if}

			{#if acct || guest}
				<div class="media">
					<div class="media-head">
						<span>Media</span>
						<label class="mini media-up">+ Upload<input type="file" accept="image/*" multiple hidden onchange={(e) => onAssetFiles((e.target as HTMLInputElement).files)} /></label>
					</div>
					{#if assetErr}<p class="ai-err">{assetErr}</p>{/if}
					{#if assets.length}
						<div class="media-grid">
							{#each assets as a (a.id)}
								<div class="media-item" title={a.name}>
									<button class="media-thumb" onclick={() => insertImage(a)} style="background-image:url({account.assetUrl(a.id)})" aria-label="Insert {a.name}"></button>
									<button class="media-del" title="Delete asset" aria-label="Delete {a.name}" onclick={() => removeAsset(a.id)}>✕</button>
								</div>
							{/each}
						</div>
					{:else}
						<p class="muted media-empty">Upload images to place them on the page.</p>
					{/if}
				</div>
			{/if}

			{#if !codeOverride}
				<div class="layers">
					<div class="layers-head">Layers</div>
					{#if !sections.length}
						<p class="muted layers-empty">No sections yet.</p>
					{:else}
						{#each sections as s (s.key)}{@render layerRow(s, 0)}{/each}
					{/if}
				</div>
			{/if}
			<div class="add-tabs">
				<button class:on={addTab === 'sections'} onclick={() => (addTab = 'sections')}>Sections</button>
				<button class:on={addTab === 'components'} onclick={() => (addTab = 'components')}>Components</button>
				<button class:on={addTab === 'templates'} onclick={() => (addTab = 'templates')}>Templates</button>
			</div>
			{#if addTab === 'templates'}
				{#each TEMPLATES as t (t.id)}
					<div class="tpl-card">
						<div class="tpl-name">{t.name}</div>
						<div class="tpl-blurb">{t.blurb}</div>
						<div class="tpl-actions">
							{#if t.sections.length}<button class="mini" onclick={() => insertTemplate(t)}>Insert</button>{/if}
							{#if !editingComponentId}<button class="mini" onclick={() => newPageFromTemplate(t)}>New page</button>{/if}
						</div>
					</div>
				{/each}
			{:else if addTab === 'sections'}
				<button class="add-item add-free" onclick={addFreeSection} title="A freeform canvas — drop components in and place them anywhere (drag to move, corner to resize)">
					<span class="add-name">+ Free canvas</span>
					<span class="add-blurb">Freeform absolute placement — drag &amp; resize</span>
				</button>
				{#each SECTIONS as def (def.id)}
					<button
						class="add-item"
						draggable="true"
						ondragstart={(e) => onPaletteDragStart(e, 'section', def.id)}
						ondragend={onDragEnd}
						onclick={() => addSection(def.id)}
						title="{def.blurb} — click to append, or drag onto the canvas"
					>
						<span class="add-name">+ {def.name}</span>
						<span class="add-blurb">{def.blurb}</span>
					</button>
				{/each}
			{:else}
				<input
					class="comp-search"
					placeholder="Search {allComponents.length} components"
					value={compSearch}
					oninput={(e) => (compSearch = (e.target as HTMLInputElement).value)}
				/>
				{#each filteredComponents as c (c.id)}
					<button
						class="add-item compact"
						draggable="true"
						ondragstart={(e) => onPaletteDragStart(e, 'component', c.id)}
						ondragend={onDragEnd}
						onclick={() => addComponent(c.id)}
						title="{c.blurb} — click to append, or drag onto the canvas"
					>+ {c.name}</button>
				{/each}
			{/if}
		</aside>
		{/if}

		<main class="canvas" style="--zoom:{zoom}" onpointermove={onCanvasPointerMove}>
			{#if codeOverride !== null}
				<!-- Code Mode override is canonical: render the whole page from the code. -->
				{#if !codeMode}
					<div class="code-banner">
						This page is edited as code.
						<button class="mini" onclick={revertToVisual}>Revert to visual</button>
					</div>
				{/if}
				<div class="frame device-{device}">
					<div use:renderSection={codeOverride}></div>
				</div>
			{:else}
			<div
				class="frame device-{device}"
				class:drop-active={dragNew !== null || dragKey !== null}
				ondragover={onCanvasDragOver}
				ondrop={onCanvasDrop}
			>
				{#if !sections.length}
					<p class="empty" class:drop-here={dragNew !== null}>
						{dragNew ? 'Drop here to add it' : 'Add sections from the left, drag them onto the canvas, or press ⌘K to search everything.'}
					</p>
				{/if}
				{#each sections as s, i (s.key)}
					{#if dropIndex === i}<div class="drop-line"></div>{/if}
					<section
						class="sec"
						class:sel={inSel(s)}
						class:dragging={s.key === dragKey}
						class:hovered={s.key === hoverKey}
						class:editing={s.key === editingKey}
						style={secStyle(s)}
						draggable={editingKey === s.key || isFree(s) ? 'false' : 'true'}
						ondragstart={(e) => onDragStart(e, s.key)}
						ondragend={onDragEnd}
						onclick={(e) => selectFromClick(e, s)}
						ondblclick={(e) => startInlineEdit(e, s)}
					>
						<div class={s.style.fg === 'light' ? 'inner awsui-dark-mode' : 'inner'} style={innerStyle(s)}>
							{#if isFree(s)}
								<!-- free canvas: children placed absolutely, drag to move, corner to resize -->
								<div class="pdrop free-frame" data-drop={s.key}>
									{#each s.children ?? [] as c (c.key)}
										<div
											class="fnode"
											class:fsel={c.key === selectedKey}
											style="left:{c.x ?? 24}px; top:{c.y ?? 24}px;{c.w ? ` width:${c.w}px;` : ''}{c.h ? ` height:${c.h}px;` : ''}"
											onpointerdown={(e) => startFDrag(e, c)}
											onclick={(e) => { e.stopPropagation(); selectedKey = c.key; showExport = false; }}
										>
											<div use:renderSection={srcOf(c)}></div>
											<span class="fresize" title="Resize" onpointerdown={(e) => startFResize(e, c)}></span>
										</div>
									{/each}
									{#if !(s.children?.length)}
										<span class="pdrop-empty">Drop components here to place them freely</span>
									{/if}
								</div>
							{:else}
								<div use:renderSection={srcOf(s)}></div>
							{/if}
						</div>
						<span class="sec-badge">⠿ {labelOf(s)}</span>
						{#if s.key === selectedKey}
							<span class="sec-tools">
								<button title="Move up" aria-label="Move up" draggable="false" onclick={(e) => { e.stopPropagation(); move(s.key, -1); }}>↑</button>
								<button title="Move down" aria-label="Move down" draggable="false" onclick={(e) => { e.stopPropagation(); move(s.key, 1); }}>↓</button>
								<button title="Duplicate" aria-label="Duplicate" draggable="false" onclick={(e) => { e.stopPropagation(); duplicate(s.key); }}>⧉</button>
								<button title="Delete" aria-label="Delete section" draggable="false" onclick={(e) => { e.stopPropagation(); removeSection(s.key); }}>✕</button>
							</span>
						{/if}
					</section>
				{/each}
				{#if dropIndex === sections.length && sections.length}<div class="drop-line"></div>{/if}
			</div>
			{/if}
			{#if cursorPeers.length}
				<div class="cursor-layer" aria-hidden="true">
					{#each cursorPeers as p (p.id)}
						<div class="rcursor" style="left:{(p.cursor?.x ?? 0) * 100}%; top:{(p.cursor?.y ?? 0) * 100}%">
							<svg width="18" height="18" viewBox="0 0 18 18" style="fill:{p.color}"><path d="M2 2 L2 14 L5.5 10.5 L8 16 L10.5 15 L8 9.5 L13 9.5 Z"/></svg>
							<span class="rcursor-name" style="background:{p.color}">{p.name}</span>
						</div>
					{/each}
				</div>
			{/if}
		</main>

		{#if codeMode}
			<aside class="code-rail">
				<div class="insp-head">
					<h2>Code</h2>
					<button class="mini" onclick={toggleCode}>Done</button>
				</div>
				<p class="muted">Raw <code>.pui</code> for this page — write logic, handlers, validation; it renders live and is what exports. Add a <code>&lt;script&gt;</code> with <code>signal</code>s and event handlers to make forms and clicks interactive.</p>
				<div class="code-ed-wrap">
					<div class="code-gutter" aria-hidden="true">
						<div class="code-gutter-inner" style="transform: translateY({-codeScrollY}px)">{codeLineNos}</div>
					</div>
					<pre class="code-hl">{@html codeHighlighted}</pre>
					<textarea
						class="code-ta"
						bind:value={codeDraft}
						oninput={(e) => { codeCaret = (e.target as HTMLTextAreaElement).selectionStart; onCodeInput(); }}
						onkeyup={(e) => (codeCaret = (e.target as HTMLTextAreaElement).selectionStart)}
						onclick={(e) => (codeCaret = (e.target as HTMLTextAreaElement).selectionStart)}
						onkeydown={codeTab}
						onscroll={codeSync}
						spellcheck="false"
						autocomplete="off"
						autocapitalize="off"
					></textarea>
				</div>
				{#if codeCompletions.length}
					<div class="code-complete">
						<div class="cc-head">Suggestions</div>
						{#each codeCompletions as c (c.label)}
							<button class="cc-item" onclick={() => applyCompletion(c)}>
								<span class="cc-label">{c.label}</span><span class="cc-detail">{c.detail}</span>
							</button>
						{/each}
					</div>
				{/if}
				{#if codeErr}<pre class="code-err">{codeErrLine !== null ? `Line ${codeErrLine}: ` : ''}{codeErr}</pre>{/if}
				<div class="code-actions">
					<button class="primary" onclick={download}>Download Page.pui</button>
					{#if codeOverride !== null}<button class="mini danger" onclick={revertToVisual}>Revert to visual</button>{/if}
				</div>
			</aside>
		{:else}
		<aside class="inspector">
			{#if showA11y}
				<div class="insp-head">
					<h2>Accessibility</h2>
					<button class="mini" onclick={scanA11y} disabled={a11yScanning}>Re-scan</button>
				</div>
				<p class="muted">axe-core checks the rendered page (WCAG 2.x). Fix these before publishing.</p>
				{#if a11yScanning}
					<p class="muted">Scanning…</p>
				{:else if a11yResults === null}
					<p class="muted">Open to scan.</p>
				{:else if a11yResults.length === 0}
					<p class="a11y-clean">✓ No accessibility violations found.</p>
				{:else}
					<p class="a11y-count">{a11yResults.length} issue{a11yResults.length === 1 ? '' : 's'} found</p>
					{#each a11yResults as v (v.id)}
						<div class="a11y-item impact-{v.impact}">
							<div class="a11y-row">
								<span class="a11y-badge">{v.impact}</span>
								<span class="a11y-id">{v.id}</span>
								<span class="a11y-n">×{v.count}</span>
							</div>
							<div class="a11y-help">{v.help}</div>
							{#if v.target}<code class="a11y-target">{v.target}</code>{/if}
							<a class="a11y-learn" href={v.helpUrl} target="_blank" rel="noreferrer">How to fix ↗</a>
						</div>
					{/each}
				{/if}
			{:else if showExport}
				<div class="insp-head"><h2>Export</h2></div>
				{#if !pageSource}
					<p class="muted">Add sections to generate .pui.</p>
				{:else}
					<p class="muted">Page.pui — hover a block to highlight its section in the canvas.</p>
					<button class="primary" onclick={download}>Download Page.pui</button>
					<div class="export-code">
						<div class="hl" use:hl={exportHead}></div>
						{#each pageSegments as seg (seg.key)}
							<div
								class="seg"
								class:hovered={seg.key === hoverKey}
								role="group"
								onmouseenter={() => (hoverKey = seg.key)}
								onmouseleave={() => { if (hoverKey === seg.key) hoverKey = null; }}
							>
								<span class="seg-label">{seg.label}</span>
								<div class="hl" use:hl={seg.code}></div>
							</div>
						{/each}
						<div class="hl" use:hl={exportFoot}></div>
					</div>
					{#if pageModules.length}
						<h3 class="export-mods-head">Component modules</h3>
						<p class="muted">Each named component exports as its own reusable <code>.pui</code>; the page imports them. Download bundles everything.</p>
						{#each pageModules as m (m.id)}
							<div class="seg">
								<span class="seg-label">{m.filename}</span>
								<div class="hl" use:hl={m.source}></div>
							</div>
						{/each}
					{/if}
				{/if}
			{:else if selected && isInstance(selected)}
				<div class="insp-head"><h2>{labelOf(selected)}</h2><button class="mini danger" onclick={() => removeSection(selected.key)}>Delete</button></div>
				<p class="muted">Instance of a named component — edit it to update every instance.</p>
				<button class="primary" onclick={() => selected.ref && enterComponentEdit(selected.ref)}>Edit component</button>

				<h3>Section style</h3>
				<label class="field"><span>Background</span>
					<span class="bg-row">
						<input type="color" value={selected.style.bg === 'transparent' ? '#ffffff' : selected.style.bg} oninput={(e) => setStyle(selected.key, { bg: (e.target as HTMLInputElement).value })} />
						<button class="mini" onclick={() => setStyle(selected.key, { bg: 'transparent' })}>None</button>
					</span>
				</label>
				<label class="field"><span>Text</span>
					<select value={selected.style.fg} onchange={(e) => setStyle(selected.key, { fg: (e.target as HTMLSelectElement).value as 'inherit' | 'light' })}>
						<option value="inherit">Dark (default)</option>
						<option value="light">Light (for dark bg)</option>
					</select>
				</label>
				<label class="field"><span>Align</span>
					<select value={selected.style.align} onchange={(e) => setStyle(selected.key, { align: (e.target as HTMLSelectElement).value as 'left' | 'center' | 'right' })}>
						<option value="left">Left</option>
						<option value="center">Center</option>
						<option value="right">Right</option>
					</select>
				</label>
				<label class="field"><span>Padding</span>
					<input type="number" value={selected.style.padY} oninput={(e) => setStyle(selected.key, { padY: Number((e.target as HTMLInputElement).value) })} />
				</label>
				<label class="field"><span>Width</span>
					<input type="number" placeholder="0 = full" value={selected.style.width} oninput={(e) => setStyle(selected.key, { width: Number((e.target as HTMLInputElement).value) })} />
				</label>
				{@render styleGroup(selected)}
			{:else if selected && isRepeat(selected)}
				<div class="insp-head"><h2>Repeater</h2><button class="mini danger" onclick={() => removeSection(selected.key)}>Delete</button></div>
				<p class="muted">Renders the components dropped inside it once per item of a data array. Bind inner content to the item’s fields.</p>
				<label class="field">
					<span>Repeat over{arrayPathOptions.length ? '' : ' (add a JSON array in Data sources)'}</span>
					<select value={selected.source ?? ''} disabled={!arrayPathOptions.length} onchange={(e) => setSource(selected.key, (e.target as HTMLSelectElement).value)}>
						<option value="">(choose an array)</option>
						{#each arrayPathOptions as p (p)}<option value={p}>{p}</option>{/each}
					</select>
				</label>
				{@render styleGroup(selected)}
			{:else if selected && isComp(selected)}
				<div class="insp-head"><h2>{labelOf(selected)}</h2><span class="insp-actions"><button class="mini" title="Turn this into a reusable component" onclick={createComponentFromSelection}>Make component</button><button class="mini danger" onclick={() => removeSection(selected.key)}>Delete</button></span></div>
				<p class="muted">{identOf(selected.comp)} — raw Parascape component</p>

				{#if takesContent(selected.comp)}
					<h3>Content</h3>
					<label class="field">
						<span>children</span>
						<input value={selected.content ?? ''} disabled={!!selected.bind} placeholder={selected.bind ? 'bound to data' : ''} oninput={(e) => setContent(selected.key, (e.target as HTMLInputElement).value)} />
					</label>
					<label class="field">
						<span>Bind to data{bindOptions.length ? (repeatAncestorFields(selected.key) ? ' (item field)' : '') : ' (add data sources first)'}</span>
						<select value={selected.bind ?? ''} disabled={!bindOptions.length} onchange={(e) => setBind(selected.key, (e.target as HTMLSelectElement).value)}>
							<option value="">(static text)</option>
							{#each bindOptions as p (p)}<option value={p}>{p}</option>{/each}
						</select>
					</label>
				{/if}

				<h3>Properties</h3>
				{#if editableProps(selected.comp).length === 0}
					<p class="muted">No editable props.</p>
				{/if}
				{#each editableProps(selected.comp) as p (p.name)}
					<label class="field">
						<span>{p.name}</span>
						{#if p.type.trim() === 'boolean'}
							<input
								type="checkbox"
								checked={!!selected.props?.[p.name]}
								onchange={(e) => setProp(selected.key, p.name, (e.target as HTMLInputElement).checked)}
							/>
						{:else if isUnion(p)}
							<select
								value={String(selected.props?.[p.name] ?? '')}
								onchange={(e) => setProp(selected.key, p.name, (e.target as HTMLSelectElement).value)}
							>
								<option value="">(default)</option>
								{#each unionOptions(p.type) as opt (opt)}<option value={opt}>{opt}</option>{/each}
							</select>
						{:else if p.type.trim() === 'number'}
							<input
								type="number"
								value={String(selected.props?.[p.name] ?? '')}
								oninput={(e) => setProp(selected.key, p.name, Number((e.target as HTMLInputElement).value))}
							/>
						{:else}
							<input
								value={String(selected.props?.[p.name] ?? '')}
								oninput={(e) => setProp(selected.key, p.name, (e.target as HTMLInputElement).value)}
							/>
						{/if}
					</label>
					{#if bindOptions.length}
						<select class="propbind" value={selected.propBind?.[p.name] ?? ""} onchange={(e) => setPropBind(selected.key, p.name, (e.target as HTMLSelectElement).value)}>
							<option value="">— bind {p.name} to data…</option>
							{#each bindOptions as o (o)}<option value={o}>{o}</option>{/each}
						</select>
					{/if}
				{/each}

				<h3>Section style</h3>
				<label class="field"><span>Background</span>
					<span class="bg-row">
						<input type="color" value={selected.style.bg === 'transparent' ? '#ffffff' : selected.style.bg} oninput={(e) => setStyle(selected.key, { bg: (e.target as HTMLInputElement).value })} />
						<button class="mini" onclick={() => setStyle(selected.key, { bg: 'transparent' })}>None</button>
					</span>
				</label>
				<label class="field"><span>Text</span>
					<select value={selected.style.fg} onchange={(e) => setStyle(selected.key, { fg: (e.target as HTMLSelectElement).value as 'inherit' | 'light' })}>
						<option value="inherit">Dark (default)</option>
						<option value="light">Light (for dark bg)</option>
					</select>
				</label>
				<label class="field"><span>Align</span>
					<select value={selected.style.align} onchange={(e) => setStyle(selected.key, { align: (e.target as HTMLSelectElement).value as 'left' | 'center' | 'right' })}>
						<option value="left">Left</option>
						<option value="center">Center</option>
						<option value="right">Right</option>
					</select>
				</label>
				<label class="field"><span>Padding</span>
					<input type="number" value={selected.style.padY} oninput={(e) => setStyle(selected.key, { padY: Number((e.target as HTMLInputElement).value) })} />
				</label>
				<label class="field"><span>Width</span>
					<input type="number" placeholder="0 = full" value={selected.style.width} oninput={(e) => setStyle(selected.key, { width: Number((e.target as HTMLInputElement).value) })} />
				</label>
				{@render styleGroup(selected)}
			{:else if selected && isFree(selected)}
				<div class="insp-head"><h2>Free canvas</h2><button class="mini danger" onclick={() => removeSection(selected.key)}>Delete</button></div>
				<p class="muted">Freeform section — drop components in and drag to place them anywhere; drag a corner to resize. {selected.children?.length ?? 0} item{(selected.children?.length ?? 0) === 1 ? '' : 's'}.</p>

				<h3>Section style</h3>
				<label class="field"><span>Background</span>
					<span class="bg-row">
						<input type="color" value={selected.style.bg === 'transparent' ? '#ffffff' : selected.style.bg} oninput={(e) => setStyle(selected.key, { bg: (e.target as HTMLInputElement).value })} />
						<button class="mini" onclick={() => setStyle(selected.key, { bg: 'transparent' })}>None</button>
					</span>
				</label>
				<label class="field"><span>Text</span>
					<select value={selected.style.fg} onchange={(e) => setStyle(selected.key, { fg: (e.target as HTMLSelectElement).value as 'inherit' | 'light' })}>
						<option value="inherit">Dark (default)</option>
						<option value="light">Light (for dark bg)</option>
					</select>
				</label>
				<label class="field"><span>Padding</span>
					<input type="number" value={selected.style.padY} oninput={(e) => setStyle(selected.key, { padY: Number((e.target as HTMLInputElement).value) })} />
				</label>
				<label class="field"><span>Width</span>
					<input type="number" placeholder="0 = full" value={selected.style.width} oninput={(e) => setStyle(selected.key, { width: Number((e.target as HTMLInputElement).value) })} />
				</label>
				{@render styleGroup(selected)}
			{:else if selected}
				<div class="insp-head"><h2>{defOf(selected).name}</h2><span class="insp-actions"><button class="mini" title="Turn this into a reusable component" onclick={createComponentFromSelection}>Make component</button><button class="mini danger" onclick={() => removeSection(selected.key)}>Delete</button></span></div>

				<h3>Content</h3>
				{#each defOf(selected).fields as f (f.key)}
					<label class="field">
						<span>{f.label}</span>
						{#if f.multiline}
							<textarea
								value={selected.values[f.key] ?? defOf(selected).defaults[f.key] ?? ''}
								oninput={(e) => setValue(selected.key, f.key, (e.target as HTMLTextAreaElement).value)}
							></textarea>
						{:else}
							<input
								value={selected.values[f.key] ?? defOf(selected).defaults[f.key] ?? ''}
								oninput={(e) => setValue(selected.key, f.key, (e.target as HTMLInputElement).value)}
							/>
						{/if}
					</label>
				{/each}

				<h3>Section style</h3>
				<label class="field"><span>Background</span>
					<span class="bg-row">
						<input type="color" value={selected.style.bg === 'transparent' ? '#ffffff' : selected.style.bg} oninput={(e) => setStyle(selected.key, { bg: (e.target as HTMLInputElement).value })} />
						<button class="mini" onclick={() => setStyle(selected.key, { bg: 'transparent' })}>None</button>
					</span>
				</label>
				<label class="field"><span>Text</span>
					<select value={selected.style.fg} onchange={(e) => setStyle(selected.key, { fg: (e.target as HTMLSelectElement).value as 'inherit' | 'light' })}>
						<option value="inherit">Dark (default)</option>
						<option value="light">Light (for dark bg)</option>
					</select>
				</label>
				<label class="field"><span>Align</span>
					<select value={selected.style.align} onchange={(e) => setStyle(selected.key, { align: (e.target as HTMLSelectElement).value as 'left' | 'center' | 'right' })}>
						<option value="left">Left</option>
						<option value="center">Center</option>
						<option value="right">Right</option>
					</select>
				</label>
				<label class="field"><span>Padding</span>
					<input type="number" value={selected.style.padY} oninput={(e) => setStyle(selected.key, { padY: Number((e.target as HTMLInputElement).value) })} />
				</label>
				<label class="field"><span>Width</span>
					<input type="number" placeholder="0 = full" value={selected.style.width} oninput={(e) => setStyle(selected.key, { width: Number((e.target as HTMLInputElement).value) })} />
				</label>
				{@render styleGroup(selected)}
			{:else}
				<p class="muted">Select a section to edit its content and style, or add one from the left.</p>
			{/if}
		</aside>
		{/if}
	</div>
</div>

<style>
	/* Chrome reads the shared theme tokens (src/lib/theme.css) so the whole
	   designer follows light / dark / auto with the rest of the site. The
	   artboard (.frame) uses --bg-elev too, so the live-compiled preview sits
	   in the same theme as the editor (its sections still carry their own
	   backgrounds). */
	:global(body) { margin: 0; }
	.designer { display: flex; flex-direction: column; height: 100vh; font: 13px/1.5 'Open Sans', system-ui, sans-serif; color: var(--fg-body); background: var(--bg-page); }
	.dtoolbar { display: flex; align-items: center; gap: 12px; padding: 8px 14px; background: var(--bg-elev); color: var(--fg-strong); border-bottom: 1px solid var(--border); flex: 0 0 auto; }
	.dtoolbar strong { font-size: 14px; }
	.dtoolbar .muted { color: var(--fg-muted); font-size: 12px; }
	.dtoolbar .spacer { flex: 1; }
	.dtoolbar button { background: var(--bg-num-pill); color: var(--fg-muted); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 5px 10px; cursor: pointer; font: inherit; }
	.dtoolbar button:hover { background: var(--bg-hover); color: var(--fg-strong); }
	.dtoolbar button.on { background: var(--accent); border-color: var(--accent); color: var(--fg-on-accent); }
	.dtoolbar button:disabled { opacity: 0.4; cursor: default; }
	.devices { display: flex; gap: 4px; }
	.zoomctl { display: flex; gap: 2px; align-items: center; }
	.zoomctl .zoom-pct { min-width: 46px; font-variant-numeric: tabular-nums; }
	.histbtns { display: flex; gap: 2px; }
	.histbtns button { padding: 5px 9px; font-size: 14px; line-height: 1; }
	/* account control + save indicator (LYK-930) */
	.acct { display: flex; align-items: center; gap: 8px; margin-left: 4px; padding-left: 10px; border-left: 1px solid var(--border); }
	.acct-name { font-size: 12px; font-weight: 600; color: var(--fg-strong); }
	.acct-save { font-size: 11px; color: var(--fg-muted); }
	.acct-save.state-saved { color: var(--good); }
	.acct-save.state-error { color: var(--bad); }
	.auth-backdrop { position: fixed; inset: 0; z-index: 50; background: rgba(15, 27, 45, 0.45); display: flex; align-items: center; justify-content: center; }
	.auth-modal { background: var(--bg-elev); color: var(--fg-body); border: 1px solid var(--border); border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); padding: 22px; width: 340px; max-width: calc(100vw - 32px); }
	.auth-modal h2 { margin: 0 0 4px; font-size: 18px; color: var(--fg-strong); }
	.auth-modal .muted { font-size: 12px; margin: 0 0 14px; }
	.auth-modal .field { display: block; margin-bottom: 12px; }
	.auth-modal .field > span { display: block; font-size: 12px; color: var(--fg-muted); margin-bottom: 4px; }
	.auth-modal input { width: 100%; box-sizing: border-box; padding: 8px 10px; border: 1px solid var(--border); border-radius: var(--radius-md); background: var(--bg-sunken); color: var(--fg-body); font: inherit; }
	.auth-modal .primary { width: 100%; margin-top: 4px; }
	.auth-err { color: var(--bad); font-size: 12px; margin: 0 0 10px; }
	.auth-switch { font-size: 12px; color: var(--fg-muted); margin: 12px 0 0; text-align: center; }
	/* command palette (LYK-942) */
	.cmdk-backdrop { position: fixed; inset: 0; z-index: 60; background: rgba(15, 27, 45, 0.45); display: flex; align-items: flex-start; justify-content: center; padding-top: 12vh; }
	.cmdk { width: 560px; max-width: calc(100vw - 32px); background: var(--bg-elev); border: 1px solid var(--border); border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); overflow: hidden; display: flex; flex-direction: column; max-height: 62vh; }
	.cmdk-input { border: 0; border-bottom: 1px solid var(--border); background: transparent; color: var(--fg-strong); font: inherit; font-size: 15px; padding: 14px 16px; outline: none; }
	.cmdk-list { overflow-y: auto; }
	.cmdk-item { display: flex; align-items: center; justify-content: space-between; gap: 12px; width: 100%; text-align: left; background: none; border: 0; padding: 9px 16px; cursor: pointer; font: inherit; color: var(--fg-body); }
	.cmdk-item.on { background: var(--bg-accent-subtle); }
	.cmdk-label { color: var(--fg-strong); }
	.cmdk-grp { font-size: 11px; color: var(--fg-muted); text-transform: uppercase; letter-spacing: 0.4px; }
	.cmdk-empty { padding: 16px; color: var(--fg-muted); font-size: 13px; }
	.cmdk-foot { border-top: 1px solid var(--border); padding: 8px 16px; font-size: 11px; color: var(--fg-muted); }
	.linkish { background: none; border: 0; color: var(--accent); cursor: pointer; font: inherit; padding: 0; text-decoration: underline; }

	/* gap shows the divider colour between the three panels */
	.cols { flex: 1; display: grid; grid-template-columns: 220px 1fr 300px; min-height: 0; background: var(--border); gap: 1px; }
	/* widen the right rail when showing the export view */
	.cols.exporting { grid-template-columns: 220px 1fr 560px; }
	/* Code Mode: no palette; canvas (live preview) + a wide code editor rail */
	.cols.coding { grid-template-columns: 1fr 620px; }
	.code-rail { background: var(--bg-sidebar); color: var(--fg-body); overflow: auto; padding: 12px; display: flex; flex-direction: column; min-height: 0; }
	.code-rail .insp-head { display: flex; align-items: center; justify-content: space-between; }
	.code-rail h2 { font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--fg-muted); margin: 0 0 4px; }
	.code-rail .muted { color: var(--fg-muted); font-size: 12px; margin: 0 0 8px; }
	.code-rail code { background: var(--bg-num-pill); padding: 0 4px; border-radius: var(--radius-sm); }
	/* syntax-highlighted editor: transparent textarea over a Shiki <pre>, with a
	   line-number gutter. Font/line-height/padding match across all three so
	   glyphs and rows line up exactly. */
	.code-ed-wrap { position: relative; flex: 1; min-height: 340px; border: 1px solid var(--border); border-radius: var(--radius-md); background: var(--bg-sunken); overflow: hidden; }
	.code-ed-wrap > pre.code-hl,
	.code-ed-wrap > .code-ta {
		position: absolute; inset: 0; margin: 0; padding: 12px 14px 12px 52px;
		font: 12px/1.55 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		white-space: pre; overflow: auto; tab-size: 2; -moz-tab-size: 2; box-sizing: border-box;
	}
	.code-ed-wrap > pre.code-hl { pointer-events: none; z-index: 0; color: var(--fg-body); }
	.code-ed-wrap > .code-ta {
		z-index: 1; resize: none; border: 0; outline: 0; background: transparent;
		color: transparent; caret-color: var(--fg-strong); -webkit-text-fill-color: transparent;
	}
	.code-ed-wrap > .code-ta::selection { background: var(--accent-ring); color: transparent; }
	.code-gutter {
		position: absolute; top: 0; bottom: 0; left: 0; width: 44px; overflow: hidden; box-sizing: border-box;
		padding: 12px 8px 12px 0; background: var(--bg-sunken); border-right: 1px solid var(--border);
		font: 12px/1.55 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; color: var(--fg-subtle);
		text-align: right; pointer-events: none; user-select: none; z-index: 3;
	}
	.code-gutter-inner { white-space: pre; }
	/* Shiki line-height fix (collapse inter-line \n) + dual-theme colour swap */
	:global(.code-ed-wrap pre.shiki) { background: transparent !important; margin: 0; padding: 0; display: block; white-space: normal; }
	:global(.code-ed-wrap pre.shiki code) { white-space: normal; display: block; }
	:global(.code-ed-wrap pre.shiki .line) { display: block; white-space: pre; min-height: 1.55em; }
	:global(.code-ed-wrap pre.shiki),
	:global(.code-ed-wrap pre.shiki span) { color: var(--shiki-light, inherit); }
	:global([data-theme='dark'] .code-ed-wrap pre.shiki),
	:global([data-theme='dark'] .code-ed-wrap pre.shiki span) { color: var(--shiki-dark, inherit); }
	.code-err { margin: 8px 0 0; padding: 8px 10px; border-radius: var(--radius-sm); background: var(--bg-sunken); color: var(--bad); border: 1px solid var(--bad); font: 11px/1.4 ui-monospace, monospace; white-space: pre-wrap; max-height: 120px; overflow: auto; }
	/* Code Mode autocomplete (LYK-939) */
	.code-complete { margin: 8px 0 0; border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--bg-sunken); max-height: 180px; overflow: auto; }
	.cc-head { font-size: 11px; text-transform: uppercase; letter-spacing: 0.4px; color: var(--fg-muted); padding: 6px 10px 2px; }
	.cc-item { display: flex; align-items: center; justify-content: space-between; gap: 10px; width: 100%; text-align: left; background: none; border: 0; padding: 5px 10px; cursor: pointer; font: inherit; color: var(--fg-strong); }
	.cc-item:hover { background: var(--bg-hover); }
	.cc-detail { font-size: 11px; color: var(--fg-muted); font-family: ui-monospace, monospace; }
	.code-actions { display: flex; gap: 8px; align-items: center; margin-top: 10px; }
	.code-actions .primary { width: auto; flex: 1; margin: 0; }
	/* banner shown on the canvas when an active code override pauses visual editing */
	.code-banner { display: flex; align-items: center; gap: 10px; margin: 0 auto 16px; max-width: 1040px; padding: 8px 12px; border-radius: var(--radius-md); background: var(--bg-accent-subtle); color: var(--fg-strong); border: 1px solid var(--accent); font-size: 13px; }

	/* Accessibility panel (LYK-931) */
	.a11y-clean { color: var(--good); font-weight: 600; }
	.a11y-count { color: var(--bad); font-weight: 600; margin: 4px 0 10px; }
	.a11y-item { border: 1px solid var(--border); border-left-width: 3px; border-radius: var(--radius-sm); padding: 8px 10px; margin-bottom: 8px; }
	.a11y-item.impact-critical { border-left-color: var(--bad); }
	.a11y-item.impact-serious { border-left-color: var(--bad); }
	.a11y-item.impact-moderate { border-left-color: var(--amber); }
	.a11y-item.impact-minor { border-left-color: var(--border-strong); }
	.a11y-row { display: flex; align-items: center; gap: 8px; }
	.a11y-badge { font-size: 10px; text-transform: uppercase; letter-spacing: 0.4px; font-weight: 700; color: var(--fg-on-accent); background: var(--fg-muted); border-radius: var(--radius-pill); padding: 1px 7px; }
	.impact-critical .a11y-badge, .impact-serious .a11y-badge { background: var(--bad); }
	.impact-moderate .a11y-badge { background: var(--amber); }
	.a11y-id { font: 12px ui-monospace, monospace; color: var(--fg-strong); }
	.a11y-n { margin-left: auto; color: var(--fg-muted); font-size: 12px; }
	.a11y-help { font-size: 12px; color: var(--fg-body); margin: 6px 0 4px; }
	.a11y-target { display: block; font: 11px ui-monospace, monospace; color: var(--fg-muted); background: var(--bg-sunken); padding: 2px 6px; border-radius: var(--radius-sm); overflow-x: auto; white-space: nowrap; }
	.a11y-learn { display: inline-block; margin-top: 6px; font-size: 12px; color: var(--accent); }

	/* visible keyboard focus for the builder UI (LYK-931) */
	.dtoolbar button:focus-visible,
	.add-item:focus-visible,
	.add-tabs button:focus-visible,
	.sec-tools button:focus-visible,
	.layer-row:focus-visible,
	.layer-del:focus-visible,
	.mini:focus-visible,
	.primary:focus-visible { outline: 2px solid var(--focus-ring); outline-offset: 1px; }
	.add-panel, .inspector { background: var(--bg-sidebar); color: var(--fg-body); overflow: auto; padding: 12px; }
	/* Layers outline tree (LYK-927) */
	/* Pages panel (LYK-929) */
	.pages { margin-bottom: 14px; border-bottom: 1px solid var(--border); padding-bottom: 10px; }
	.pages-head { display: flex; align-items: center; justify-content: space-between; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--fg-muted); margin-bottom: 6px; }
	.page-row { display: flex; align-items: center; gap: 4px; border-radius: var(--radius-sm); }
	.page-row.active { background: var(--bg-accent-subtle); }
	.page-pick { flex: 1; display: flex; flex-direction: column; align-items: flex-start; gap: 1px; background: none; border: 0; cursor: pointer; padding: 5px 8px; text-align: left; font: inherit; color: var(--fg-body); border-radius: var(--radius-sm); min-width: 0; }
	.page-pick:hover { background: var(--bg-hover); }
	.page-row.active .page-pick { color: var(--accent); }
	.page-name { font-size: 12px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%; }
	.page-route { font: 10px ui-monospace, monospace; color: var(--fg-subtle); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%; }
	.page-del { flex: 0 0 auto; border: 0; background: none; color: var(--fg-subtle); cursor: pointer; font-size: 11px; padding: 0 4px; opacity: 0; }
	.page-row:hover .page-del { opacity: 1; }
	.page-del:hover { color: var(--bad); }
	.page-settings { margin-top: 8px; padding-top: 8px; border-top: 1px dashed var(--border); }
	.page-settings .field { margin-bottom: 6px; }
	.page-settings .field > span { display: block; font-size: 11px; color: var(--fg-muted); margin-bottom: 2px; }
	.page-settings .seo-head { margin-top: 10px; margin-bottom: 4px; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: var(--fg-subtle); }
	.page-settings input { width: 100%; box-sizing: border-box; padding: 4px 7px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--bg-elev); color: var(--fg-body); font: 12px inherit; }
	/* version history (LYK-943) */
	.history { margin-top: 10px; padding-top: 8px; border-top: 1px dashed var(--border); }
	.hist-head { display: flex; align-items: center; justify-content: space-between; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--fg-muted); margin-bottom: 6px; }
	.hist-row { display: flex; align-items: center; gap: 6px; padding: 4px 0; border-bottom: 1px solid var(--border-soft); }
	.hist-meta { flex: 1; min-width: 0; display: flex; flex-direction: column; }
	.hist-label { font-size: 12px; color: var(--fg-strong); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
	.hist-time { font-size: 10px; color: var(--fg-subtle); }
	.hist-act { flex: 0 0 auto; font-size: 11px; padding: 2px 8px; border: 1px solid var(--border); border-radius: var(--radius-pill); background: var(--bg-elev); color: var(--fg-body); cursor: pointer; }
	.hist-act:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
	.hist-del { flex: 0 0 auto; border: none; background: none; color: var(--fg-subtle); cursor: pointer; font-size: 12px; padding: 2px 4px; }
	.hist-del:hover:not(:disabled) { color: var(--bad); }
	.hist-empty { font-size: 11px; color: var(--fg-subtle); line-height: 1.4; margin: 2px 0 0; }
	/* data sources (LYK-945) */
	.datasrc { margin-top: 10px; padding-top: 8px; border-top: 1px dashed var(--border); }
	.datasrc > summary { cursor: pointer; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--fg-muted); user-select: none; }
	.ds-note { font-size: 11px; color: var(--fg-subtle); line-height: 1.4; margin: 6px 0; }
	.ds-json { width: 100%; box-sizing: border-box; min-height: 120px; font: 11px/1.5 ui-monospace, SFMono-Regular, Menlo, monospace; padding: 6px 8px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--bg-elev); color: var(--fg-body); resize: vertical; }
	.ds-err { font-size: 11px; color: var(--bad); margin: 4px 0 0; }
	.ds-url { display: flex; gap: 6px; margin-bottom: 6px; }
	.ds-url input { flex: 1; min-width: 0; box-sizing: border-box; padding: 4px 7px; font-size: 12px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--bg-elev); color: var(--fg-body); }
	.ds-url button { flex: 0 0 auto; }
	.pf-bound { background: var(--bg-accent-subtle); color: var(--accent); border-radius: 3px; padding: 0 4px; outline: 1px dashed var(--accent-ring); }
	/* repeater (LYK-945) */
	.repeat-zone { position: relative; outline: 1px dashed var(--accent-ring); outline-offset: 3px; border-radius: var(--radius-sm); }
	.repeat-badge { position: absolute; top: -10px; inset-inline-end: 6px; font-size: 10px; font-weight: 600; padding: 1px 7px; border-radius: var(--radius-pill); background: var(--accent); color: var(--fg-on-accent); pointer-events: none; }
	.propbind { width: 100%; box-sizing: border-box; margin: -4px 0 8px; font-size: 11px; color: var(--accent); border: 1px dashed var(--border-strong); border-radius: var(--radius-sm); background: var(--bg-page); padding: 3px 6px; }
	.layers { margin-bottom: 14px; max-height: 38vh; overflow: auto; border-bottom: 1px solid var(--border); padding-bottom: 8px; }
	.layers-head { font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--fg-muted); margin: 0 0 6px; }
	.layers-empty { font-size: 12px; color: var(--fg-subtle); }
	/* named components / symbols (LYK-949) */
	.comp-edit-banner { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 7px 14px; background: var(--bg-accent-subtle); color: var(--fg-strong); border-bottom: 1px solid var(--accent); font-size: 13px; }
	.mycomp { margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
	.mycomp-head { font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--fg-muted); margin: 0 0 6px; }
	.mycomp-row { display: flex; align-items: center; gap: 4px; margin-bottom: 4px; }
	.mycomp-row.active .mycomp-chip { border-color: var(--accent); color: var(--accent); }
	.mycomp-chip { flex: 1; text-align: left; background: var(--bg-num-pill); color: var(--fg-strong); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 5px 8px; cursor: grab; font: inherit; }
	.mycomp-chip:hover:not(:disabled) { background: var(--bg-hover); }
	.mycomp-chip:disabled { opacity: 0.45; cursor: not-allowed; }
	.mycomp-edit, .mycomp-del { background: var(--bg-num-pill); color: var(--fg-muted); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 5px 7px; cursor: pointer; font: inherit; font-size: 11px; }
	.mycomp-edit:hover { background: var(--bg-hover); color: var(--fg-strong); }
	.mycomp-del:hover { background: var(--bad); color: #fff; border-color: var(--bad); }
	.insp-actions { display: flex; gap: 6px; }
	.export-mods-head { margin-top: 16px; }
	/* AI generation (LYK-936) */
	.ai-box { margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
	.ai-head { font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--fg-muted); margin: 0 0 6px; }
	.ai-prompt { width: 100%; box-sizing: border-box; min-height: 52px; resize: vertical; padding: 7px 9px; border: 1px solid var(--border); border-radius: var(--radius-md); background: var(--bg-sunken); color: var(--fg-body); font: inherit; }
	.ai-go { width: 100%; margin-top: 6px; }
	.ai-err { color: var(--bad); font-size: 11px; margin: 6px 0 0; }
	/* media library (LYK-935) + publish (LYK-934) */
	.media { margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
	.media-head { display: flex; align-items: center; justify-content: space-between; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--fg-muted); margin-bottom: 6px; }
	.media-up { cursor: pointer; }
	.media-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; }
	.media-item { position: relative; }
	.media-thumb { width: 100%; aspect-ratio: 1; border: 1px solid var(--border); border-radius: var(--radius-sm); background-size: cover; background-position: center; background-color: var(--bg-sunken); cursor: pointer; padding: 0; }
	.media-thumb:hover { border-color: var(--accent); }
	.media-del { position: absolute; top: -6px; right: -6px; width: 18px; height: 18px; border-radius: 50%; background: var(--bad); color: #fff; border: 2px solid var(--bg-elev); cursor: pointer; font-size: 10px; line-height: 1; padding: 0; opacity: 0; }
	.media-item:hover .media-del { opacity: 1; }
	.media-empty { font-size: 12px; }
	.pub-link { font-size: 12px; color: var(--accent); text-decoration: none; padding: 5px 8px; }
	.pub-link:hover { text-decoration: underline; }
	/* templates (LYK-937) */
	.tpl-card { border: 1px solid var(--border); border-radius: var(--radius-md); padding: 8px 10px; margin-bottom: 8px; background: var(--bg-num-pill); }
	.tpl-name { font-weight: 600; color: var(--fg-strong); font-size: 13px; }
	.tpl-blurb { font-size: 11px; color: var(--fg-muted); margin: 2px 0 6px; }
	.tpl-actions { display: flex; gap: 6px; }
	/* free canvas (LYK-936) */
	.free-frame { position: relative; min-height: 320px; width: 100%; border: 1px dashed var(--border); border-radius: var(--radius-md); background-image: radial-gradient(var(--border) 1px, transparent 1px); background-size: 16px 16px; }
	.free-frame.nest-over { border-color: var(--accent); background-color: var(--bg-accent-subtle); }
	.fnode { position: absolute; cursor: grab; touch-action: none; }
	.fnode:active { cursor: grabbing; }
	.fnode.fsel { outline: 2px solid var(--accent); outline-offset: 2px; }
	.fresize { position: absolute; right: -5px; bottom: -5px; width: 12px; height: 12px; background: var(--accent); border: 2px solid var(--bg-elev); border-radius: 2px; cursor: nwse-resize; opacity: 0; }
	.fnode.fsel .fresize, .fnode:hover .fresize { opacity: 1; }
	/* per-node element style controls (LYK-933) */
	.style-group { margin-top: 14px; border-top: 1px solid var(--border); padding-top: 10px; }
	.style-group > summary { cursor: pointer; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--fg-muted); margin-bottom: 8px; user-select: none; }
	.style-group .bg-row { display: flex; gap: 6px; align-items: center; }
	.style-group .bg-row input { flex: 1; min-width: 0; }
	.style-group .bg-row select { flex: 0 0 auto; max-width: 92px; }
	/* LYK-946: theme colour-token swatches (read from theme.css) */
	.style-group .swatches { display: flex; flex-wrap: wrap; gap: 4px; margin: -2px 0 8px; }
	.style-group .swatch { width: 18px; height: 18px; padding: 0; border: 1px solid var(--border); border-radius: var(--radius-sm); cursor: pointer; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.15); }
	.style-group .swatch:hover { transform: scale(1.12); border-color: var(--fg-muted); }
	.style-group .swatch.on { outline: 2px solid var(--accent); outline-offset: 1px; }
	.bp-note { font-size: 11px; color: var(--accent); margin: 0 0 8px; }
	.layer-row { display: flex; align-items: center; gap: 4px; padding: 2px 6px 2px 8px; border-radius: var(--radius-sm); }
	.layer-row:hover { background: var(--bg-hover); }
	.layer-row.sel { background: var(--bg-accent-subtle); color: var(--accent); }
	.layer-pick { flex: 1; min-width: 0; display: flex; align-items: center; gap: 6px; background: none; border: 0; cursor: pointer; font: inherit; color: inherit; text-align: left; padding: 4px 0; }
	.layer-icon { font-size: 11px; color: var(--fg-subtle); flex: 0 0 auto; }
	.layer-label { flex: 1; min-width: 0; font-size: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
	.layer-del { flex: 0 0 auto; border: 0; background: none; color: var(--fg-subtle); cursor: pointer; font-size: 11px; padding: 0 4px; border-radius: var(--radius-sm); opacity: 0; }
	.layer-row:hover .layer-del { opacity: 1; }
	.layer-del:hover { color: var(--bad); }
	.add-panel h2, .inspector h2 { font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--fg-muted); margin: 0 0 10px; }
	.inspector h3 { font-size: 12px; margin: 18px 0 8px; color: var(--fg-muted); }
	.add-tabs { display: flex; gap: 4px; margin-bottom: 10px; }
	.add-tabs button { flex: 1; padding: 6px; border: 1px solid var(--border); background: var(--bg-elev); border-radius: var(--radius-md); cursor: pointer; font: inherit; color: var(--fg-muted); }
	.add-tabs button.on { background: var(--accent); border-color: var(--accent); color: var(--fg-on-accent); }
	.comp-search { width: 100%; box-sizing: border-box; padding: 6px 8px; margin-bottom: 8px; border: 1px solid var(--border); border-radius: var(--radius-md); background: var(--bg-elev); color: var(--fg-body); font: inherit; }
	.add-item { display: block; width: 100%; text-align: left; padding: 8px 10px; margin-bottom: 6px; border: 1px solid var(--border); border-radius: var(--radius-md); background: var(--bg-elev); color: var(--fg-body); cursor: grab; font: inherit; }
	.add-item:hover { background: var(--bg-accent-subtle); border-color: var(--accent); }
	.add-item:active { cursor: grabbing; }
	.add-item.compact { padding: 6px 10px; font-weight: 600; }
	.add-name { display: block; font-weight: 600; }
	.add-blurb { display: block; color: var(--fg-muted); font-size: 11px; }

	.canvas { position: relative; overflow: auto; background: var(--bg-sunken); padding: 24px; }
	/* live collaboration (LYK-944) */
	.collab { display: flex; align-items: center; gap: 4px; padding: 0 8px; }
	.collab-dot { width: 8px; height: 8px; border-radius: 50%; background: #2ec16a; box-shadow: 0 0 0 3px rgba(46, 193, 106, 0.2); }
	.collab-peer { width: 22px; height: 22px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; color: #fff; font-size: 11px; font-weight: 700; border: 2px solid var(--bg-elev); margin-left: -6px; }
	.collab-peer:first-of-type { margin-left: 2px; }
	.collab-count { font-size: 11px; color: var(--fg-muted); margin-left: 4px; }
	.cursor-layer { position: absolute; inset: 0; pointer-events: none; z-index: 40; }
	.rcursor { position: absolute; transform: translate(-2px, -2px); transition: left 0.06s linear, top 0.06s linear; }
	.rcursor svg { display: block; filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.4)); }
	.rcursor-name { position: absolute; left: 14px; top: 12px; white-space: nowrap; color: #fff; font-size: 10px; font-weight: 700; padding: 1px 6px; border-radius: 8px; }
	.frame { background: var(--bg-elev); margin: 0 auto; box-shadow: var(--shadow-md); border-radius: var(--radius-md); overflow: hidden; transition: max-width 0.15s ease; min-height: 80px; transform: scale(var(--zoom, 1)); transform-origin: top center; }
	/* dashed outline while a palette item or section is being dragged over */
	.frame.drop-active { outline: 2px dashed var(--accent); outline-offset: 4px; }
	.frame.device-desktop { max-width: 100%; }
	.frame.device-tablet { max-width: 768px; }
	.frame.device-mobile { max-width: 375px; }
	.empty { color: var(--fg-subtle); text-align: center; padding: 80px 20px; }
	.empty.drop-here { color: var(--accent); background: var(--bg-accent-subtle); border: 2px dashed var(--accent); border-radius: var(--radius-md); margin: 16px; padding: 64px 20px; }

	.sec { position: relative; cursor: grab; outline: 2px solid transparent; outline-offset: -2px; }
	.sec:active { cursor: grabbing; }
	.sec:hover { outline-color: var(--accent-ring); }
	.sec.sel { outline-color: var(--accent); }
	.sec.dragging { opacity: 0.4; }
	/* highlighted from the export view when its code block is hovered */
	.sec.hovered { outline-color: var(--amber); outline-width: 3px; }
	/* The preview is interactive enough to select nodes (data-pk), edit text
	   (data-pf) and drop into containers (data-drop), but text isn't selectable
	   so grabbing content still drags the whole section. */
	.inner { user-select: none; }
	.sec.editing { cursor: text; }
	.sec.editing .sec-badge { opacity: 0; }
	/* editable text markers live inside the live-compiled preview (so :global). */
	:global(.sec .pf) { cursor: text; border-radius: 3px; transition: background 0.1s, outline-color 0.1s; }
	:global(.sec .pf:hover) { outline: 1px dashed var(--accent); outline-offset: 2px; }
	:global(.sec .pf[contenteditable='true']) { outline: 2px solid var(--accent); background: var(--bg-accent-subtle); user-select: text; }
	/* container drop zones (nesting) */
	:global(.sec .pdrop) { min-height: 12px; transition: outline-color 0.1s, background 0.1s; }
	:global(.sec .pdrop.nest-over) { outline: 2px dashed var(--amber); outline-offset: 2px; background: var(--bg-amber-subtle); }
	:global(.sec .pdrop-empty) { display: block; padding: 14px; text-align: center; color: var(--fg-subtle); border: 1px dashed var(--border); border-radius: var(--radius-sm); font-size: 12px; }
	/* the blue insert indicator shown between sections while dragging */
	.drop-line { height: 3px; background: var(--accent); border-radius: 2px; }
	.sec-badge { position: absolute; top: 0; left: 0; background: var(--accent); color: var(--fg-on-accent); font-size: 11px; padding: 2px 8px; border-radius: 0 0 6px 0; opacity: 0; transition: opacity 0.1s ease; pointer-events: none; }
	.sec:hover .sec-badge, .sec.sel .sec-badge { opacity: 1; }
	.sec-tools { position: absolute; top: 4px; right: 4px; display: flex; gap: 2px; }
	.sec-tools button { background: var(--accent); color: var(--fg-on-accent); border: 0; width: 24px; height: 24px; border-radius: var(--radius-sm); cursor: pointer; font-size: 12px; line-height: 1; }
	.sec-tools button:hover { background: var(--accent-hover); }
	:global(.sec-err) { color: var(--bad); background: var(--bg-sunken); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 6px 10px; font: 11px/1.4 ui-monospace, monospace; white-space: pre-wrap; }

	.insp-head { display: flex; align-items: center; justify-content: space-between; }
	.field { display: block; margin-bottom: 10px; }
	.field > span { display: block; color: var(--fg-muted); font-size: 12px; margin-bottom: 3px; }
	.field input[type=text], .field input:not([type]), .field input[type=number], .field select, .field textarea { width: 100%; box-sizing: border-box; padding: 6px 8px; border: 1px solid var(--border); border-radius: var(--radius-md); background: var(--bg-elev); color: var(--fg-body); font: inherit; }
	.field textarea { min-height: 64px; resize: vertical; }
	.bg-row { display: flex; gap: 6px; align-items: center; }
	.bg-row input[type=color] { width: 44px; height: 30px; padding: 0; border: 1px solid var(--border); border-radius: var(--radius-md); }
	.mini { border: 1px solid var(--border); background: var(--bg-elev); color: var(--fg-body); border-radius: var(--radius-md); padding: 4px 8px; cursor: pointer; font: 12px inherit; }
	.danger { color: var(--bad); border-color: var(--bad); }
	.primary { width: 100%; padding: 8px; border: 0; border-radius: var(--radius-md); background: var(--accent); color: var(--fg-on-accent); cursor: pointer; font: inherit; font-weight: 600; margin-bottom: 10px; }
	.primary:hover { background: var(--accent-hover); }
	.code { background: var(--bg-sunken); color: var(--fg-body); padding: 12px; border-radius: var(--radius-md); font: 11px/1.5 ui-monospace, SFMono-Regular, Menlo, monospace; white-space: pre; overflow: auto; max-height: 420px; }
	/* export view: per-section highlighted code blocks */
	.export-code { background: var(--bg-sunken); border: 1px solid var(--border); border-radius: var(--radius-md); overflow: auto; padding: 4px; }
	.export-code .seg { border-radius: var(--radius-sm); transition: background 0.1s ease; }
	.export-code .seg.hovered { background: var(--bg-amber-subtle); outline: 1px solid var(--amber); }
	.seg-label { display: block; padding: 4px 10px 0; color: var(--amber); font: 600 10px/1.4 ui-monospace, monospace; text-transform: uppercase; letter-spacing: 0.5px; }
	.export-code .hl :global(.shiki) { margin: 0; padding: 6px 10px; background: transparent !important; font: 12px/1.55 ui-monospace, SFMono-Regular, Menlo, monospace; tab-size: 2; -moz-tab-size: 2; white-space: pre; overflow-x: auto; }
	.export-code .hl { color: var(--fg-body); font: 12px/1.55 ui-monospace, SFMono-Regular, Menlo, monospace; tab-size: 2; -moz-tab-size: 2; white-space: pre; padding: 6px 10px; }
	.export-code .hl:has(.shiki) { padding: 0; }
	/* Dual-theme Shiki: pui-shiki runs with defaultColor:false, so each token
	   carries --shiki-light / --shiki-dark vars but no color. Pick the active
	   one off [data-theme] (light is the default). */
	:global(.export-code .shiki),
	:global(.export-code .shiki span) { color: var(--shiki-light, inherit); }
	:global([data-theme="dark"] .export-code .shiki),
	:global([data-theme="dark"] .export-code .shiki span) { color: var(--shiki-dark, inherit); }
</style>
