{
  "name": "parascape",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "For-funzies .pui (Svelte 5) port of a Cloudscape slice. Not affiliated with AWS. 1:1 API on the reactively-interesting components; Para signals over React hooks.",
  "scripts": {
    "dev": "vite",
    "demos": "vite --open=/demos/",
    "demos:smoke": "bun run build && bun tests/visual/demos-smoke.mjs",
    "demos:test": "bun demos/para-inline-snippets.test.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "status": "bun tests/visual/gen-status.mjs",
    "visual": "bun tests/visual/box-shoot.mjs",
    "visual:wide": "bun tests/visual/wide-shoot.mjs",
    "visual:cp": "bun tests/visual/cp-shoot.mjs",
    "visual:ann": "bun tests/visual/ann-shoot.mjs",
    "conformance": "bun run vendor:verify && vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "visual:chart": "bun tests/visual/chart-shoot.mjs",
    "visual:area": "bun tests/visual/area-shoot.mjs",
    "visual:pie": "bun tests/visual/pie-shoot.mjs",
    "vendor:gen": "bun tests/visual/gen-tokens.mjs",
    "vendor:verify": "bun tests/visual/gen-tokens.mjs --check",
    "conformance:score": "node tests/conformance/scoreboard.mjs"
  },
  "devDependencies": {
    "@cloudscape-design/components": "3.0.1297",
    "@cloudscape-design/design-tokens": "3.0.87",
    "@cloudscape-design/global-styles": "1.0.59",
    "@lyku/para-preprocess": "^0.0.1-pre.13",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5",
    "@tsconfig/svelte": "^5.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "3.2.4",
    "@vitest/runner": "^3",
    "d3-shape": "1.3.7",
    "jsdom": "^29.1.1",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.3",
    "prettier-plugin-svelte": "^3.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "svelte": "^5.55.7",
    "svelte-check": "^4.1.4",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3"
  }
}
