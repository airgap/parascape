<!--
  Parascape <Cards> â€” faithful port of
  @cloudscape-design/components/cards/index.js (Cards forwardRef +
  CardsList + CardItem) + cards-layout-helper.js + table/tools-header.js.
  Public defaults: variant='container', cardsPerRow=[], no selection.
  isRefresh=true (Cloudscape 3.x) â‡’ computedVariant = variant
  ('container'); InternalContainerAsSubstep gets
  variant = computedVariant==='container' ? 'cards' : computedVariant
  â‡’ Container variant='cards', disableContentPaddings=true,
  disableHeaderPaddings=false. Structure verbatim:
    <div clsx(styles.root)>
      <InternalContainerAsSubstep variant='cards' disableContentPaddings
        header={hasToolsHeader && <div clsx(styles.header[undef],
          styles['header-refresh'], styles['header-variant-container']
          [undef]) â†’ ToolsHeader>}>
        <div clsx(hasToolsHeader&&styles['has-header'],
          styles.refresh, styles['header-variant-container'][undef])>
          {status ?? <CardsList>}
        </div>
      </InternalContainerAsSubstep>
    </div>
  Cards' own styles.css.js has NO `header` / `header-variant-container`
  keys (verified â€” only `header-refresh` / `header-variant-full-page`),
  so for the default variant the header wrapper = clsx('header-refresh')
  and the content wrapper = clsx('has-header','refresh').
  CardsList = <ol clsx(styles.list, styles[`list-grid-${columns||1}`])
    role={selectable?'group':undefined} aria-labelledby aria-label>
    { items â†’ CardItem }</ol>. columns = getCardsPerRow(contentBoxWidth,
  cardsPerRow) â€” transcribed verbatim; contentBoxWidth measured off the
  styles.root div (React merges measureRef there) via ResizeObserver
  contentRect, exactly like Cloudscape's useContainerQuery.
  CardItem (non-selectable path) = <li clsx(styles.card) role={listItem
    Role}><InternalItemCard fullHeight header={<div styles['card-
    header']><div clsx(styles['card-header-inner'])>{cardDefinition.
    header(item)}</div></div>}>{ visibleSectionsDefinition.length>0 &&
    visibleSectionsDefinition.map(({width=100,header,content,id}) =>
      <div styles.section style="width:${width}%">
        [header â†’ <div styles['section-header']>{header}</div>]
        [content â†’ <div styles['section-content']>{content(item)}</div>]
      </div>) }</InternalItemCard></li>
  visibleSectionsDefinition = cardDefinition.sections (filtered by
  visibleSections when given). Composes parity Containerâś… /
  ItemCardâś… (â†’ StructuredItemâś…). ToolsHeader uses table's CSS module
  (vendored table.styles.js, same as Table.pui) â€” isHeaderString ?
  <span id> : header, then hasTools && tools row. Selection
  (selectionType / SelectionControl / entireCardClickable /
  card-selected), sticky header, mobile full-page footer-pagination,
  the renderAriaLive live-region, loading spinner, and analytics
  metadata are documented-omitted (not the default/static path â€”
  consistent with all prior ports).
-->
<script lang="pts">
	import Checkbox from './Checkbox.pui';
	import Container from './Container.pui';
	import ItemCard from './ItemCard.pui';
	import RadioButton from './RadioButton.pui';
	import styles from '../cloudscape/cards.styles.js';
	import thStyles from '../cloudscape/table.styles.js';
	import '../cloudscape/cards.scoped.css';

	type Section = {
		id?: string;
		width?: number;
		header?: import('svelte').Snippet | string;
		content?: (item: any) => unknown;
	};
	type CardDefinition = {
		header?: (item: any) => unknown;
		sections?: Section[];
	};

	let {
		items = [],
		cardDefinition = {},
		cardsPerRow = [],
		header = undefined,
		filter = undefined,
		pagination = undefined,
		preferences = undefined,
		empty = undefined,
		visibleSections = undefined,
		ariaLabels = undefined,
		variant = 'container',
		selectionType = undefined,
		selectedItems = $bindable([]),
		onSelectionChange = undefined,
		trackBy = undefined,
		class: extraClass = undefined,
		...rest
	}: {
		items?: any[];
		cardDefinition?: CardDefinition;
		cardsPerRow?: Array<{ minWidth?: number; cards: number }>;
		header?: import('svelte').Snippet | string;
		filter?: import('svelte').Snippet;
		pagination?: import('svelte').Snippet;
		preferences?: import('svelte').Snippet;
		empty?: import('svelte').Snippet | string;
		visibleSections?: string[];
		ariaLabels?: { cardsLabel?: string; itemSelectionLabel?: string };
		variant?: 'container' | 'cards' | 'full-page';
		selectionType?: 'single' | 'multi';
		selectedItems?: any[];
		onSelectionChange?: (e: { detail: { selectedItems: any[] } }) => void;
		trackBy?: string | ((item: any) => string);
		class?: string;
		[k: string]: unknown;
	} = $props();

	const cx = (...a: unknown[]) => a.flat(Infinity).filter(Boolean).join(' ');
	const S = styles as Record<string, string>;
	const TH = thStyles as Record<string, string>;
	const snip = (v: unknown) => typeof v === 'function';
	const has = (v: unknown) => v !== null && v !== undefined;

	// isRefresh=true (Cloudscape 3.x) â‡’ computedVariant = variant
	const computedVariant = variant;
	const containerVariant = computedVariant === 'container' ? 'cards' : computedVariant;

	derived hasToolsHeader = has(header) || has(filter) || has(pagination) || has(preferences);
	const isHeaderString = typeof header === 'string';
	// isLabelledByHeader = !ariaLabels?.cardsLabel && !!header (verbatim)
	derived isLabelledByHeader = !ariaLabels?.cardsLabel && has(header);
	const headingId = 'parascape-cards-heading';

	// cards-layout-helper.js â€” transcribed verbatim
	const WIDTHS = [1920, 1400, 1200, 992, 768];
	const defaultCardsPerRow = WIDTHS.map((value, index, widths) => ({
		minWidth: value,
		cards: widths.length + 1 - index,
	}));
	function getCardsPerRow(width: number, config: Array<{ minWidth?: number; cards: number }>) {
		if (config.length === 0) config = defaultCardsPerRow;
		let perRow = 1;
		const sorted = config
			.slice()
			.map((v) => ({ minWidth: v.minWidth || 0, cards: v.cards }))
			.sort((a, b) => b.minWidth - a.minWidth);
		sorted.some((layout) => {
			if (width >= layout.minWidth) {
				perRow = layout.cards;
				return true;
			}
		});
		return perRow;
	}

	signal rootEl: HTMLElement | undefined = undefined;
	signal measuredWidth = 0;
	effect {
		if (!rootEl) return;
		const m = () => {
			if (rootEl) measuredWidth = rootEl.getBoundingClientRect().width;
		};
		requestAnimationFrame(m);
		const ro =
			typeof ResizeObserver !== 'undefined'
				? new ResizeObserver((entries) => {
						measuredWidth = entries[0].contentRect.width;
					})
				: undefined;
		ro?.observe(rootEl);
		return () => ro?.disconnect();
	};
	derived columns = getCardsPerRow(measuredWidth, cardsPerRow);

	// CardsList: selectable=false (no selectionType) â‡’ listRole/listItemRole undefined
	derived visibleSectionsDefinition = (() => {
		const defs = cardDefinition.sections || [];
		return visibleSections
			? defs.filter((s) => s.id && visibleSections.indexOf(s.id) !== -1)
			: defs;
	})();

	// Selection bookkeeping mirrors Cloudscape's useSelection. trackBy
	// can be a key string or a per-item function; we resolve identity
	// the same way for `isItemSelected` and for `onSelectionChange`'s
	// emitted `selectedItems` so referential identity round-trips.
	const selectable = !!selectionType;
	const itemKey = (item: any, index: number) =>
		typeof trackBy === 'function'
			? trackBy(item)
			: typeof trackBy === 'string'
				? String(item?.[trackBy])
				: String(index);
	const isItemSelected = (item: any, index: number) => {
		const k = itemKey(item, index);
		return (selectedItems || []).some((s, i) => itemKey(s, i) === k);
	};
	const toggleSelection = (item: any, index: number) => {
		const k = itemKey(item, index);
		const prev = selectedItems || [];
		const already = prev.some((s, i) => itemKey(s, i) === k);
		const next =
			selectionType === 'single'
				? already
					? []
					: [item]
				: already
					? prev.filter((s, i) => itemKey(s, i) !== k)
					: [...prev, item];
		// Self-assign so `bind:selectedItems` reflects the toggle; still
		// fire onSelectionChange for the controlled Cloudscape API.
		selectedItems = next;
		onSelectionChange?.({ detail: { selectedItems: next } });
	};
</script>

<div class={cx(extraClass, S.root)} bind:this={rootEl} {...rest}>
	<Container
		variant={containerVariant}
		disableContentPaddings
		header={hasToolsHeader ? toolsHeader : undefined}
	>
		<div class={cx(hasToolsHeader && S['has-header'], S.refresh)}>
			{#if empty && items.length === 0}
				<div class={S.empty}
					>{#if snip(empty)}{@render (empty as import('svelte').Snippet)()}{:else}{empty}{/if}</div
				>
			{:else}
				<ol
					class={cx(S.list, S[`list-grid-${columns || 1}`])}
					aria-labelledby={isLabelledByHeader ? headingId : undefined}
					aria-label={ariaLabels?.cardsLabel}
				>
					{#each items as item, index (index)}
						{@const selected = selectable && isItemSelected(item, index)}
						{#snippet cardHeader()}
							<div class={S['card-header']}>
								<div class={cx(S['card-header-inner'], selectable && S['card-header-inner-selectable'])}
									>{cardDefinition.header ? cardDefinition.header(item) : ''}</div
								>
								{#if selectable}<div class={S['selection-control']}
										>{#if selectionType === 'single'}<RadioButton
												checked={selected}
												ariaLabel={ariaLabels?.itemSelectionLabel}
												onChange={() => toggleSelection(item, index)}
											/>{:else}<Checkbox
												checked={selected}
												ariaLabel={ariaLabels?.itemSelectionLabel}
												onChange={() => toggleSelection(item, index)}
											/>{/if}</div>{/if}
							</div>
						{/snippet}
						<li class={cx(S.card, selected && S['card-selected'])}>
							<ItemCard fullHeight highlighted={selected} header={cardHeader}>
								{#if visibleSectionsDefinition.length > 0}
									{#each visibleSectionsDefinition as sec, si (sec.id || si)}
										<div class={S.section} style={`width: ${sec.width ?? 100}%`}>
											{#if has(sec.header)}<div class={S['section-header']}
													>{#if snip(sec.header)}{@render (sec.header as import('svelte').Snippet)()}{:else}{sec.header}{/if}</div
												>{/if}
											{#if sec.content}<div class={S['section-content']}
													>{sec.content(item)}</div
												>{/if}
										</div>
									{/each}
								{/if}
							</ItemCard>
						</li>
					{/each}
				</ol>
			{/if}
		</div>
	</Container>
</div>

<!-- ToolsHeader (table CSS module), declared at top level so it does NOT
     shadow the `header` PROP (a {#snippet header} inside <Container>
     would make {@render header()} recurse). isHeaderString ? <span id> :
     header, then hasTools && <div.tools> with filter / right-aligned
     pagination+preferences. -->
{#snippet toolsHeader()}
	<div class={cx(S['header-refresh'])}>
		{#if isHeaderString}<span id={headingId}>{header}</span
			>{:else if snip(header)}{@render (header as import('svelte').Snippet)()}{/if}
		{#if has(filter) || has(pagination) || has(preferences)}
			<div class={TH.tools}>
				{#if has(filter)}<div class={TH['tools-filtering']}
						>{@render (filter as import('svelte').Snippet)()}</div
					>{/if}
				{#if has(pagination) || has(preferences)}
					<div class={TH['tools-align-right']}>
						{#if has(pagination)}<div class={TH['tools-pagination']}
								>{@render (pagination as import('svelte').Snippet)()}</div
							>{/if}
						{#if has(preferences)}<div class={TH['tools-preferences']}
								>{@render (preferences as import('svelte').Snippet)()}</div
							>{/if}
					</div>
				{/if}
			</div>
		{/if}
	</div>
{/snippet}
